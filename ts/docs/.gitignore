# DocFX build output and intermediate artifacts
_site/
_site_pdf/
obj/
api/
.cache/
log.txt
.manifest

# --- Generated navigation (regenerated by scripts/build-wiki.mjs) ---
# The architecture content itself is committed; only its generated toc.yml is a
# build artifact.
/architecture/toc.yml

# --- Staged package/agent docs (crawled from ts/packages at build time) ---
# These sections are assembled from each package's README; only the curated
# landing page (index.md) is committed.
/packages/*
!/packages/index.md
/agents/*
!/agents/index.md

# --- Interactive Action Browser (built by tools/actionBrowser) ---
# Intentionally NOT ignored: docs-pr-amend.yml regenerates the generated HTML
# + JSON and commits them onto the PR branch so the catalog is reviewable in
# the same PR that changed the agents. The docs-site deploy builds its own
# copy separately.
