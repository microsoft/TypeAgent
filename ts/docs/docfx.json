{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "build": {
    "content": [
      {
        "files": ["**/*.md", "**/toc.yml"],
        "exclude": [
          "_site/**",
          "obj/**",
          "scripts/**",
          ".cache/**",
          "README.md",
          "plans/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "media/**",
          "**/*.html",
          "**/*.png",
          "**/*.jpg",
          "**/*.jpeg",
          "**/*.gif",
          "**/*.svg",
          "**/*.webp",
          "**/*.bmp",
          "**/*.ico"
        ],
        "exclude": ["_site/**", "obj/**"]
      }
    ],
    "globalMetadata": {
      "_appName": "TypeAgent",
      "_appTitle": "TypeAgent Engineering Wiki",
      "_appFooter": "TypeAgent — Microsoft. Sample code exploring single-personal-agent architecture.",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/microsoft/TypeAgent",
        "branch": "main",
        "apiSpecFolder": "ts/docs"
      },
      "pdf": false
    },
    "fileMetadata": {
      "_disableContribution": {
        "packages/**": true,
        "agents/**": true
      }
    },
    "dest": "_site",
    "template": ["default", "modern"],
    "markdownEngineName": "markdig",
    "disableGitFeatures": false,
    "sitemap": {
      "baseUrl": "https://eng.ms/typeagent"
    }
  }
}
