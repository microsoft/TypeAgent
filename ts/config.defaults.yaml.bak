# TypeAgent default configuration.
#
# Committed to the repository. This file holds NON-SECRET defaults
# that should apply to every developer and every environment unless
# explicitly overridden.
#
# Per-developer overrides go in `ts/config.local.yaml` (gitignored).
# Live secrets are fetched from Azure Key Vault at startup once the
# Phase 2 work lands; until then, secrets continue to live in `.env`
# (also gitignored), which is loaded as a fallback.
#
# See packages/config/README.md for the full precedence and flattening
# rules.

azureOpenAI:
  # Default tuning knobs for Azure OpenAI clients. These match
  # the values previously hard-coded in .env.template / README.
  defaultAuth: identity
  maxConcurrency: 4
  maxTimeoutMs: 120000
  maxRetryAttempts: 3
  # Enable JSON response_format on chat models. Existing
  # `aiclient` code treats any non-empty value as truthy.
  responseFormat: true
