{
  "name": "workflow-cli",
  "version": "0.0.1",
  "private": true,
  "description": "CLI for running, validating, and inspecting workflow IR files.",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/examples/workflow/cli"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "bin": {
    "workflow": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run tsc",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "prettier": "prettier --check . --ignore-path ../../../.prettierignore",
    "prettier:fix": "prettier --write . --ignore-path ../../../.prettierignore",
    "tsc": "tsc -b"
  },
  "dependencies": {
    "workflow-engine": "workspace:*",
    "workflow-model": "workspace:*"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "~5.4.5"
  }
}
