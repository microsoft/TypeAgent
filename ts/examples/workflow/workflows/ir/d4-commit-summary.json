{
  "kind": "workflow",
  "version": "1",
  "description": "Generate a conventional commit message from staged changes.",
  "constants": {
    "commitPromptPrefix": {
      "schema": {
        "type": "string"
      },
      "value": "You are an expert developer. Given the following git diff of staged changes, write a conventional commit message. Use the format: <type>(<scope>): <subject>\\n\\n<body>\\n\\nTypes: feat, fix, refactor, docs, test, chore, style, perf. Keep the subject under 72 characters. The body should explain what changed and why, not how. Be concise.\\n\\nDiff:\\n"
    }
  },
  "entry": "d4-commit-summary",
  "workflows": {
    "d4-commit-summary": {
      "inputSchema": {
        "type": "object",
        "required": ["repoPath"],
        "properties": {
          "repoPath": {
            "type": "string",
            "description": "Absolute path to the git repo."
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "entry": "getDiff",
      "nodes": {
        "getDiff": {
          "kind": "task",
          "task": "shell.exec",
          "inputSchema": {
            "type": "object",
            "required": ["command"],
            "properties": {
              "command": {
                "type": "string"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "cwd": {
                "type": "string"
              }
            }
          },
          "outputSchema": {
            "type": "object",
            "required": ["stdout", "stderr", "exitCode"],
            "properties": {
              "stdout": {
                "type": "string"
              },
              "stderr": {
                "type": "string"
              },
              "exitCode": {
                "type": "integer"
              }
            }
          },
          "inputs": {
            "command": "git",
            "args": ["diff", "--staged"],
            "cwd": {
              "$from": "input",
              "name": "repoPath"
            }
          },
          "next": "buildPrompt",
          "bind": "diffResult"
        },
        "buildPrompt": {
          "kind": "task",
          "task": "text.template",
          "inputSchema": {
            "type": "object",
            "required": ["template", "vars"],
            "properties": {
              "template": {
                "type": "string"
              },
              "vars": {
                "type": "object"
              }
            }
          },
          "outputSchema": {
            "type": "string"
          },
          "inputs": {
            "template": "{{prefix}}{{diff}}",
            "vars": {
              "prefix": {
                "$from": "constant",
                "name": "commitPromptPrefix",
                "path": []
              },
              "diff": {
                "$from": "scope",
                "name": "diffResult",
                "path": ["stdout"]
              }
            }
          },
          "next": "generateMessage",
          "bind": "prompt"
        },
        "generateMessage": {
          "kind": "task",
          "task": "llm.generate",
          "inputSchema": {
            "type": "object",
            "required": ["prompt"],
            "properties": {
              "prompt": {
                "type": "string"
              }
            }
          },
          "outputSchema": {
            "type": "string"
          },
          "inputs": {
            "prompt": {
              "$from": "scope",
              "name": "prompt"
            }
          },
          "bind": "llmResult"
        }
      },
      "output": {
        "message": {
          "$from": "scope",
          "name": "llmResult"
        }
      }
    }
  }
}
