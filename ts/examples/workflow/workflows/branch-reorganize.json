      "inputs": {
        "template": "set -e\ngit checkout -b {{branchPrefix}}validation-merge \"{{baseBranch}}\"\nfor branch in {{branches}}; do\n  git merge --no-edit \"$branch\"\ndone",
        "vars": {
          "baseBranch": {
            "$from": "input",
            "name": "baseBranch"
          },
          "branchPrefix": {
            "$from": "input",
            "name": "branchPrefix"
