    "buildValidationScript": {
      "kind": "task",
      "task": "text.template",
      "inputSchema": {
        "type": "object",
        "required": [
          "template",
          "vars"
        ],
        "properties": {
          "template": {
            "type": "string"
          },
          "vars": {
            "type": "object"
          }
        }
