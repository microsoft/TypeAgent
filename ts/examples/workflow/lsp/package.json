{
  "name": "workflow-lsp",
  "version": "0.0.1",
  "private": true,
  "description": "Language Server Protocol implementation for the workflow DSL (.wf).",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/examples/workflow/lsp"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "bin": {
    "workflow-lsp": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "npm run tsc",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "jest-esm": "node --no-warnings --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit",
    "prettier": "prettier --check . --ignore-path ../../../.prettierignore",
    "prettier:fix": "prettier --write . --ignore-path ../../../.prettierignore",
    "test": "npm run test:local",
    "test:local": "pnpm run jest-esm --testPathPattern=\".*[.]spec[.]js\"",
    "tsc": "tsc -b"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "workflow-dsl": "workspace:*",
    "workflow-engine": "workspace:*",
    "workflow-model": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.7",
    "@types/node": "^22.10.5",
    "jest": "^29.7.0",
    "vscode-languageserver-protocol": "^3.17.5",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "~5.4.5"
  }
}
