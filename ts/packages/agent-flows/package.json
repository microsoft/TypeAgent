{
  "name": "@typeagent/agent-flows",
  "version": "0.0.1",
  "description": "Shared workflow infrastructure for TypeAgent flow agents",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/agent-flows"
  },
  "license": "MIT",
