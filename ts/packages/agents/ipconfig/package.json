{
  "name": "ipconfig-agent",
  "version": "0.0.1",
  "private": true,
  "description": "TypeAgent agent for ipconfig",
  "keywords": [
    "typeagent-agent"
  ],
  "typeagent": {
    "defaultAgentName": "ipconfig"
  },
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/agents/ipconfig"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "exports": {
    "./agent/manifest": "./src/ipconfigManifest.json",
    "./agent/handlers": "./dist/ipconfigActionHandler.js"
  },
  "scripts": {
    "agc": "agc -i ./src/ipconfigSchema.agr -o ./dist/ipconfigSchema.ag.json",
    "asc": "asc -i ./src/ipconfigSchema.ts -o ./dist/ipconfigSchema.pas.json -t IpconfigActions",
    "build": "concurrently npm:tsc npm:asc npm:agc",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "tsc": "tsc -b"
  },
  "dependencies": {
    "@typeagent/agent-sdk": "workspace:*"
  },
  "devDependencies": {
    "@typeagent/action-grammar-compiler": "workspace:*",
    "@typeagent/action-schema-compiler": "workspace:*",
    "concurrently": "^9.1.2",
    "rimraf": "^6.0.1",
    "typescript": "~5.4.5"
  }
}
