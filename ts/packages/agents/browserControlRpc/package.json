{
  "name": "@typeagent/browser-control-rpc",
  "version": "0.0.1",
  "description": "Browser control types and content script RPC client for TypeAgent",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/agents/browserControlRpc"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "exports": {
    "./types": "./dist/browserControl.js",
    "./webAgentMessageTypes": "./dist/webAgentMessageTypes.js",
    "./serviceTypes": "./dist/serviceTypes.js",
    "./extensionEvents": "./dist/extensionEvents.js",
    "./platformServices": "./dist/platformServices.js",
    "./htmlReducer": "./dist/crossContextHtmlReducer.js",
    "./pdfTypes": "./dist/pdfTypes.js",
    "./answerEnhancement": "./dist/answerEnhancement.js",
