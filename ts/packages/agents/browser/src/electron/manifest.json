{
  "manifest_version": 3,
  "name": "Browser TypeAgent",
  "version": "1.0",
  "description": "Automates various browser actions.",
  "action": {},
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://localhost:9000/"],
      "js": ["contentScript.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["https://*/*"],
      "js": ["agentActivation.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://*/*", "http://localhost:9000/"],
      "js": ["webTypeAgentMain.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["https://*/*"],
      "js": ["uiEventsDispatcher.js"],
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.wsj.com/puzzles/crossword*",
        "https://embed.universaluclick.com/*",
        "https://data.puzzlexperts.com/puzzleapp*",
        "https://nytsyn.pzzl.com/cwd_seattle*",
        "https://*.seattletimes.com/games-nytimes-crossword*",
        "https://*.denverpost.com/games/daily-crossword*",
        "https://*.denverpost.com/puzzles/*",
        "https://*.bestcrosswords.com/bestcrosswords/guestconstructor*"
      ],
      "js": ["sites/crossword.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://paleobiodb.org/*"],
      "js": ["sites/paleobiodb.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*/*"],
      "js": ["sites/webflow.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sites/paleobiodb.js", "sites/paleobiodbSchema.mts"],
      "matches": ["https://paleobiodb.org/*"]
    },
    {
      "resources": ["uiEventsDispatcher.js"],
      "matches": ["https://*/*"]
    }
  ],
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"]
}
