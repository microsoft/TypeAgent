// Browser Agent Grammar - Core Actions
// Covers the most common browser operations

import { BrowserActions } from "./browserActionSchema.mts";

<Start> : BrowserActions = <OpenPage>
          | <ClosePage>
          | <Navigation>
          | <Scrolling>
          | <FollowLink>
          | <TabControl>
          | <Zoom>
          | <ReadPage>
          | <Screenshot>;

// ===== Open Web Page =====
<OpenPage> = open $(site:wildcard) -> { actionName: "openWebPage", parameters: { site } }
             | go to $(site:wildcard) -> { actionName: "openWebPage", parameters: { site } }
             | navigate to $(site:wildcard) -> { actionName: "openWebPage", parameters: { site } }
             | browse to $(site:wildcard) -> { actionName: "openWebPage", parameters: { site } }
             | visit $(site:wildcard) -> { actionName: "openWebPage", parameters: { site } };

// ===== Close Page =====
<ClosePage> = close (the)? (web)? page -> { actionName: "closeWebPage" }
              | close (the)? tab -> { actionName: "closeWebPage" }
              | close all (web)? pages -> { actionName: "closeAllWebPages" }
              | close all tabs -> { actionName: "closeAllWebPages" };

// ===== Navigation =====
<Navigation> = go back -> { actionName: "goBack" }
               | back -> { actionName: "goBack" }
               | go forward -> { actionName: "goForward" }
               | forward -> { actionName: "goForward" }
               | reload (the)? page -> { actionName: "reloadPage" }
               | refresh (the)? page -> { actionName: "reloadPage" };

// ===== Scrolling =====
<Scrolling> = scroll down -> { actionName: "scrollDown" }
              | scroll up -> { actionName: "scrollUp" }
              | page down -> { actionName: "scrollDown" }
              | page up -> { actionName: "scrollUp" };

// ===== Follow Link =====
<FollowLink> = follow (the)? link $(keywords:wildcard) -> { actionName: "followLinkByText", parameters: { keywords } }
               | click (on)? (the)? link $(keywords:wildcard) -> { actionName: "followLinkByText", parameters: { keywords } }
               | click (on)? $(keywords:wildcard) -> { actionName: "followLinkByText", parameters: { keywords } };

// ===== Tab Control =====
<TabControl> = switch to tab $(tabDescription:wildcard) -> { actionName: "changeTab", parameters: { tabDescription } }
               | go to tab $(tabDescription:wildcard) -> { actionName: "changeTab", parameters: { tabDescription } }
               | next tab -> { actionName: "changeTab", parameters: { tabDescription: "next" } };

// ===== Zoom =====
<Zoom> = zoom in -> { actionName: "zoomIn" }
         | zoom out -> { actionName: "zoomOut" }
         | reset zoom -> { actionName: "zoomReset" };

// ===== Read Page =====
<ReadPage> = read (the)? page -> { actionName: "readPageContent" }
             | read (the)? page (out loud)? -> { actionName: "readPageContent" }
             | stop reading -> { actionName: "stopReadPageContent" };

// ===== Screenshot =====
<Screenshot> = take (a)? screenshot -> { actionName: "captureScreenshot" }
               | capture (the)? screen -> { actionName: "captureScreenshot" }
               | screenshot -> { actionName: "captureScreenshot" };
