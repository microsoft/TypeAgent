{
  "name": "browser-typeagent",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "keywords": [
    "typeagent-agent"
  ],
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/agents/browser"
  },
  "license": "MIT",
  "author": "Microsoft",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./agent/manifest": "./src/agent/manifest.json",
    "./agent/handlers": "./dist/agent/browserActionHandler.mjs",
    "./agent/indexing": "./dist/agent/indexing/browserIndexingService.js"
  },
  "main": "index.js",
  "scripts": {
    "agc": "agc -i ./src/agent/browserSchema.agr -o ./dist/agent/browserSchema.ag.json",
    "asc": "asc -i ./src/agent/browserActionSchema.mts -o ./dist/agent/browserSchema.pas.json -t BrowserActions -e BrowserEntities",
    "build": "fluid-build . -t build",
    "build:dev": "fluid-build . -t build:dev",
    "build:views": "fluid-build . -t build:views",
    "clean": "rimraf dist deploy && rimraf -g **/*.tsbuildinfo *.done.build.log",
    "dev:client": "vite serve",
    "prettier": "prettier --check . --ignore-path ../../../.prettierignore",
    "prettier:fix": "prettier --write . --ignore-path ../../../.prettierignore",
    "test": "npm run test:local",
    "test:local": "jest",
    "tsc:agent": "tsc -p src/agent/tsconfig.json",
    "tsc:puppeteer": "tsc -p src/puppeteer/tsconfig.json",
    "tsc:views:client:typecheck": "tsc -p src/views/client/pdf/tsconfig.json",
    "tsc:views:server": "tsc -p src/views/server/tsconfig.json",
    "tsc:views:shared": "tsc -p src/views/shared/tsconfig.json",
    "vite:views:client": "vite build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.150",
    "@typeagent/action-schema": "workspace:*",
    "@typeagent/agent-flows": "workspace:*",
    "@typeagent/agent-rpc": "workspace:*",
    "@typeagent/agent-sdk": "workspace:*",
    "@typeagent/agent-server-client": "workspace:*",
    "@typeagent/agent-server-protocol": "workspace:*",
    "@typeagent/aiclient": "workspace:*",
    "@typeagent/browser-control-rpc": "workspace:*",
    "@typeagent/common-utils": "workspace:*",
    "@typeagent/config": "workspace:*",
    "@typeagent/dispatcher-rpc": "workspace:*",
    "@typeagent/dispatcher-types": "workspace:*",
    "@typeagent/websocket-utils": "workspace:*",
    "azure-ai-foundry": "workspace:*",
    "chalk": "^5.4.1",
    "chat-ui": "workspace:*",
    "cheerio": "^1.1.0",
    "conversation-memory": "workspace:*",
    "debug": "^4.4.0",
    "dompurify": "^3.4.11",
    "express": "^4.22.0",
    "express-rate-limit": "^7.5.0",
    "graphology": "^0.25.4",
    "graphology-communities-louvain": "^2.0.1",
    "graphology-layout": "^0.6.1",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-layout-noverlap": "^0.4.1",
    "graphology-types": "^0.24.7",
    "html-to-text": "^9.0.5",
    "jsdom": "^28.1.0",
    "jsonpath": "^1.2.0",
    "knowledge-processor": "workspace:*",
    "knowpro": "workspace:*",
    "pdfjs-dist": "^5.3.31",
    "puppeteer": "^24.15.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-adblocker": "^2.13.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "readline": "^1.3.0",
    "sanitize-filename": "^1.6.3",
    "taskflow-typeagent": "workspace:*",
    "textpro": "workspace:*",
    "typeagent": "workspace:*",
    "typechat": "^0.1.1",
    "typescript": "~5.4.5",
    "website-memory": "workspace:*",
    "websocket-channel-server": "workspace:*",
    "ws": "^8.21.0",
    "xss": "^1.0.15",
    "yaml": "^2.8.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@fluidframework/build-tools": "^0.57.0",
    "@typeagent/action-grammar-compiler": "workspace:*",
    "@typeagent/action-schema-compiler": "workspace:*",
    "@types/chrome": "^0.0.256",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.21",
    "@types/html-to-text": "^9.0.4",
    "@types/jest": "^29.5.7",
    "@types/jquery": "^3.5.14",
    "@types/jsdom": "^28.0.0",
    "@types/jsonpath": "0.2.4",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "jest-chrome": "^0.8.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^28.1.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.3.2",
    "vite": "^6.4.3"
  },
  "fluidBuild": {
    "tasks": {
      "agc": {
        "dependsOn": [
          "@typeagent/action-grammar-compiler#tsc"
        ],
        "files": {
          "inputGlobs": [
            "src/agent/browserSchema.agr"
          ],
          "outputGlobs": [
            "dist/agent/browserSchema.ag.json"
          ]
        }
      },
      "asc": {
        "dependsOn": [
          "@typeagent/action-schema-compiler#tsc"
        ],
        "files": {
          "inputGlobs": [
            "src/agent/browserActionSchema.mts"
          ],
          "outputGlobs": [
            "dist/agent/browserSchema.pas.json"
          ]
        }
      },
      "build": {
        "dependsOn": [
          "^build",
          "asc",
          "agc",
          "build:views",
          "tsc:agent",
          "tsc:puppeteer"
        ],
        "script": false
      },
      "build:dev": {
        "dependsOn": [
          "^build",
          "build:views",
          "tsc:agent",
          "tsc:puppeteer"
        ],
        "script": false
      },
      "tsc:agent": {
        "dependsOn": [
          "^build"
        ]
      },
      "build:views": {
        "dependsOn": [
          "tsc:views:server",
          "tsc:views:client:typecheck",
          "vite:views:client"
        ],
        "script": false
      },
      "tsc:views:server": [
        "tsc:views:shared"
      ],
      "tsc:views:client:typecheck": [
        "tsc:views:shared"
      ],
      "vite:views:client": {
        "dependsOn": [
          "tsc:views:shared"
        ],
        "files": {
          "inputGlobs": [
            "src/views/client/**/*"
          ],
          "outputGlobs": [
            "dist/views/public/**/*"
          ]
        }
      }
    }
  },
  "typeagent": {
    "defaultAgentName": "browser"
  }
}
