{
  "extends": "../../../../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "strict": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "vite.config.ts"]
}
