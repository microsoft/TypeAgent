<AddBreakpoint> = add a breakpoint at line $(line:word) in $(file:wildcard) -> {
  actionName: "addBreakpoint",
  parameters: {
    file,
    line
  }
}
| set a breakpoint in the file $(file:wildcard) at line $(line:word) -> {
  actionName: "addBreakpoint",
  parameters: {
    file,
    line
  }
}
| add a breakpoint on line $(line:word) of $(file:wildcard) with the condition $(condition:wildcard) -> {
  actionName: "addBreakpoint",
  parameters: {
    file,
    line,
    condition
  }
}
| need a breakpoint at line $(line:word) in $(file:wildcard), but only if $(condition:wildcard) is true -> {
  actionName: "addBreakpoint",
  parameters: {
    file,
    line,
    condition
  }
};

<RemoveBreakpoint> = remove the breakpoint with ID $(breakpointId:word) -> {
  actionName: "removeBreakpoint",
  parameters: {
    breakpointId
  }
}
| delete the breakpoint identified by $(breakpointId:word) -> {
  actionName: "removeBreakpoint",
  parameters: {
    breakpointId
  }
}
| get rid of the breakpoint $(breakpointId:word) -> {
  actionName: "removeBreakpoint",
  parameters: {
    breakpointId
  }
}
| remove the breakpoint with the ID $(breakpointId:word) -> {
  actionName: "removeBreakpoint",
  parameters: {
    breakpointId
  }
};

<FindInFiles> = search for $(searchTerm:wildcard) in all the files with $(fileTypes:wildcard) extensions -> {
