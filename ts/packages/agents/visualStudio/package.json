{
  "name": "visualstudio-agent",
  "version": "0.0.1",
  "private": true,
  "description": "TypeAgent agent for Visual Studio (EnvDTE bridge)",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/agents/visualStudio"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "exports": {
    "./agent/manifest": "./src/visualStudioManifest.json",
    "./agent/handlers": "./dist/visualStudioActionHandler.js"
  },
  "scripts": {
    "agc": "agc -i ./src/visualStudioSchema.agr -o ./dist/visualStudioSchema.ag.json",
    "asc": "asc -i ./src/visualStudioSchema.ts -o ./dist/visualStudioSchema.pas.json -t VisualStudioActions",
    "build": "concurrently npm:tsc npm:asc npm:agc",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "tsc": "tsc -b"
  },
  "dependencies": {
    "@typeagent/agent-sdk": "workspace:*",
    "@typeagent/websocket-utils": "workspace:*",
    "debug": "^4.4.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@typeagent/action-grammar-compiler": "workspace:*",
    "@typeagent/action-schema-compiler": "workspace:*",
    "@types/debug": "^4.1.12",
    "@types/ws": "^8.5.10",
    "concurrently": "^9.1.2",
    "rimraf": "^6.0.1",
    "typescript": "~5.4.5"
  },
  "fluidBuild": {
    "tasks": {
      "agc": {
        "dependsOn": [
          "@typeagent/action-grammar-compiler#tsc"
        ],
        "files": {
          "inputGlobs": [
            "src/visualStudioSchema.agr"
          ],
          "outputGlobs": [
            "dist/visualStudioSchema.ag.json"
          ]
        }
      },
      "asc": {
        "dependsOn": [
          "@typeagent/action-schema-compiler#tsc"
        ],
        "files": {
          "inputGlobs": [
            "src/visualStudioSchema.ts"
          ],
          "outputGlobs": [
            "dist/visualStudioSchema.pas.json"
          ]
        }
      }
    }
  }
}
