import { TaskFlowActions } from "./schema/userActions.mts";

<Start> : TaskFlowActions = <listTaskFlows> | <deleteTaskFlow>;

<listTaskFlows> = (<Polite>)? (<Greeting>)? (<Acknowledgement>)? (show me | list | display) (all)? (the)? (available)? task flows -> { actionName: "listTaskFlows" };

<deleteTaskFlow> [spacing=optional] = (delete | remove) (the)? task flow $(name:wildcard) -> { actionName: "deleteTaskFlow", parameters: { name } };
