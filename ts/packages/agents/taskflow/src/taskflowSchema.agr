<Start> = <listTaskFlows> | <createTopSongsPlaylist> | <createTopSongsPlaylistClaude> | <weeklyEmailDigest> | <playPopularKpopSong> | <playPopularKpopSongClaude>;

// Action rules
<listTaskFlows> = (<Polite>)? (<Greeting>)? (<Acknowledgement>)? (show me | list | display) (all)? (the)? (available)? task flows -> { actionName: "listTaskFlows", parameters: {} };

<createTopSongsPlaylist> = (<Polite>)? (<Greeting>)? (<Acknowledgement>)? create (a)? (top)? $(quantity:number) $(genre:wildcard) (songs)? playlist (for | from) (the)? $(timePeriod:wildcard) -> { actionName: "createTopSongsPlaylist", parameters: { genre, quantity, timePeriod } };

<createTopSongsPlaylistClaude> = (<Polite>)? (<Greeting>)? (<Acknowledgement>)? create (a)? (top)? $(quantity:number) $(genre:wildcard) (songs)? playlist using claude (for | from) (the)? $(timePeriod:wildcard) -> { actionName: "createTopSongsPlaylistClaude", parameters: { genre, quantity, timePeriod } };

<weeklyEmailDigest> =
    send (me)? (a)? (weekly)? email digest (for)? $(timePeriod:wildcard)
      -> { actionName: "weeklyEmailDigest", parameters: { timePeriod } }
  | give me (my)? (weekly)? email digest (for)? $(timePeriod:wildcard)
      -> { actionName: "weeklyEmailDigest", parameters: { timePeriod } }
  | email digest (for)? $(timePeriod:wildcard)
      -> { actionName: "weeklyEmailDigest", parameters: { timePeriod } }
  | (weekly)? email digest
      -> { actionName: "weeklyEmailDigest", parameters: {} }
  | summarize (my)? (recent)? emails (for)? $(timePeriod:wildcard)
      -> { actionName: "weeklyEmailDigest", parameters: { timePeriod } };

<playPopularKpopSong> =
    play the most popular kpop song $(timePeriod:wildcard)
      -> { actionName: "playPopularKpopSong", parameters: { timePeriod } }
  |     play the top kpop song $(timePeriod:wildcard)
      -> { actionName: "playPopularKpopSong", parameters: { timePeriod } }
  |     get the most popular kpop song $(timePeriod:wildcard) and play it
      -> { actionName: "playPopularKpopSong", parameters: { timePeriod } }
  |     find the hottest kpop song $(timePeriod:wildcard) and play it
      -> { actionName: "playPopularKpopSong", parameters: { timePeriod } }
  |     play the number one kpop song $(timePeriod:wildcard)
      -> { actionName: "playPopularKpopSong", parameters: { timePeriod } };

<playPopularKpopSongClaude> =
    claude play the most popular kpop song $(timePeriod:wildcard)
      -> { actionName: "playPopularKpopSongClaude", parameters: { timePeriod } }
  |     claude play the top kpop song $(timePeriod:wildcard)
      -> { actionName: "playPopularKpopSongClaude", parameters: { timePeriod } }
  |     claude get the most popular kpop song $(timePeriod:wildcard) and play it
      -> { actionName: "playPopularKpopSongClaude", parameters: { timePeriod } }
  |     claude find the hottest kpop song $(timePeriod:wildcard) and play it
      -> { actionName: "playPopularKpopSongClaude", parameters: { timePeriod } }
  |     claude play the number one kpop song $(timePeriod:wildcard)
      -> { actionName: "playPopularKpopSongClaude", parameters: { timePeriod } };
