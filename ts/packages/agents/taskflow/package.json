{
  "name": "taskflow-typeagent",
  "version": "0.0.1",
  "private": true,
  "description": "TypeAgent TaskFlow — user-taught macros over TypeAgent actions",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/agents/taskflow"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "exports": {
    "./agent/manifest": "./manifest.json",
    "./agent/handlers": "./dist/actionHandler.mjs",
    "./recipe": "./dist/types/recipe.js"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "prettier": "prettier --check . --ignore-path ../../../.prettierignore",
    "prettier:fix": "prettier --write . --ignore-path ../../../.prettierignore",
    "tsc": "tsc -b"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.101",
    "@typeagent/agent-sdk": "workspace:*",
    "debug": "^4.3.4",
    "typescript": "~5.4.5"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1"
  }
}
