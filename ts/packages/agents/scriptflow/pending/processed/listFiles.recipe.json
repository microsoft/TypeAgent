{
  "version": 1,
  "actionName": "listFiles",
  "description": "List files in a directory with optional filtering",
  "displayName": "List Files",
  "parameters": [
    {
      "name": "path",
      "type": "path",
      "required": false,
      "description": "Directory to list",
      "default": "."
    },
    {
      "name": "filter",
      "type": "string",
      "required": false,
      "description": "File name filter (supports wildcards)",
      "default": "*"
    }
  ],
  "script": {
    "language": "powershell",
    "body": "param([string]$Path = '.', [string]$Filter = '*')\nGet-ChildItem -Path $Path -Filter $Filter | Format-Table Name, Length, LastWriteTime -AutoSize",
    "expectedOutputFormat": "table"
  },
  "grammarPatterns": [
    {
      "pattern": "list (all)? (the)? files (in|at|under) $(path:wildcard)",
      "isAlias": false,
      "examples": ["list files in downloads", "list all the files in src"]
    },
    {
      "pattern": "ls $(path:wildcard)",
      "isAlias": true,
      "examples": ["ls .", "ls downloads"]
    },
    {
      "pattern": "dir $(path:wildcard)",
      "isAlias": true,
      "examples": ["dir .", "dir src"]
    },
    {
      "pattern": "show (me)? (the)? files (in|of) $(path:wildcard)",
      "isAlias": false,
      "examples": ["show me the files in documents"]
    }
  ],
  "sandbox": {
    "allowedCmdlets": [
      "Get-ChildItem",
      "Format-Table",
      "Select-Object",
      "Sort-Object"
    ],
    "allowedPaths": ["$env:USERPROFILE", "$PWD", "$env:TEMP"],
    "allowedModules": ["Microsoft.PowerShell.Management"],
    "maxExecutionTime": 30,
    "networkAccess": false
  },
  "source": {
    "type": "manual",
    "timestamp": "2026-03-12T12:00:00Z"
  }
}
