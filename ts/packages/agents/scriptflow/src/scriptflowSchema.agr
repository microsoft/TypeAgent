import { ScriptFlowActions } from "./schema/scriptActions.mts";

<Start> : ScriptFlowActions = <listScriptFlows> | <deleteScriptFlow> | <importScriptFlow>;

// Built-in action rules (dynamic flows are registered at runtime via addGeneratedRules)
<listScriptFlows> = (<Polite>)? (<Greeting>)? (<Acknowledgement>)? (show me | list | display) (all)? (the)? (available)? script flows -> { actionName: "listScriptFlows" };

<deleteScriptFlow> [spacing=optional] =
    (delete | remove) (the)? script flow $(name:wildcard)
      -> { actionName: "deleteScriptFlow", parameters: { name } };

<importScriptFlow> [spacing=optional] =
    import (a)? (powershell)? script (flow)? (from)? $(filePath:wildcard)
      -> { actionName: "importScriptFlow", parameters: { filePath } };
