{
  "name": "studio-agent",
  "version": "0.0.1",
  "private": true,
  "description": "TypeAgent Studio agent — the AI / conversational presenter over the @typeagent/core Studio runtime (inspect, and later run/validate/author)",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/agents/studio"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "exports": {
    "./agent/manifest": "./src/studioManifest.json",
    "./agent/handlers": "./dist/studioActionHandler.js"
  },
  "scripts": {
    "asc": "asc -i ./src/studioSchema.ts -o ./dist/studioSchema.pas.json -t StudioActions",
    "build": "concurrently npm:tsc npm:asc",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "jest-esm": "node --no-warnings --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "prettier": "prettier --check . --ignore-path ../../../.prettierignore",
    "prettier:fix": "prettier --write . --ignore-path ../../../.prettierignore",
    "test": "npm run test:local",
    "test:local": "pnpm run jest-esm --testPathPattern=\".*[.]spec[.]js\"",
    "tsc": "tsc -b src test"
  },
  "dependencies": {
    "@typeagent/agent-rpc": "workspace:*",
    "@typeagent/agent-sdk": "workspace:*",
    "@typeagent/core": "workspace:*",
    "debug": "^4.4.0",
    "studio-service": "workspace:*",
    "websocket-utils": "workspace:*",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@typeagent/action-schema-compiler": "workspace:*",
    "@types/debug": "^4.1.12",
    "@types/jest": "^29.5.7",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "~5.4.5"
  },
  "fluidBuild": {
    "tasks": {
      "asc": {
        "dependsOn": [
          "@typeagent/action-schema-compiler#tsc"
        ],
        "files": {
          "inputGlobs": [
            "src/studioSchema.ts"
          ],
          "outputGlobs": [
            "dist/studioSchema.pas.json"
          ]
        }
      }
    }
  }
}
