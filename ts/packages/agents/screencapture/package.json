{
  "name": "screencapture-agent",
  "version": "0.0.1",
  "private": true,
  "description": "Screen capture and recording dispatcher agent",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/agents/screencapture"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "exports": {
    "./agent/manifest": "./src/screencaptureManifest.json",
    "./agent/handlers": "./dist/screencaptureActionHandler.js"
  },
  "scripts": {
    "agc": "agc -i ./src/screencaptureSchema.agr -o ./dist/screencaptureSchema.ag.json",
    "asc": "asc -i ./src/screencaptureSchema.ts -o ./dist/screencaptureSchema.pas.json -t ScreencaptureAction -a ScreencaptureActivity",
    "build": "concurrently npm:tsc npm:asc npm:agc",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "jest-esm": "node --no-warnings --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "prettier": "prettier --check . --ignore-path ../../../.prettierignore",
    "prettier:fix": "prettier --write . --ignore-path ../../../.prettierignore",
    "test": "npm run test:local",
    "test:local": "pnpm run jest-esm --testPathPattern=\".*[.]spec[.]js\"",
    "tsc": "tsc -b src test"
  },
  "dependencies": {
    "@typeagent/agent-sdk": "workspace:*",
    "@typeagent/aiclient": "workspace:*",
    "debug": "^4.4.0",
    "typeagent": "workspace:*"
  },
  "devDependencies": {
    "@typeagent/action-grammar-compiler": "workspace:*",
    "@typeagent/action-schema-compiler": "workspace:*",
    "@types/debug": "^4.1.12",
    "@types/jest": "^29.5.7",
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "~5.4.5"
  },
  "fluidBuild": {
    "tasks": {
      "agc": {
        "dependsOn": [
          "@typeagent/action-grammar-compiler#tsc"
        ],
        "files": {
          "inputGlobs": [
            "src/screencaptureSchema.agr"
          ],
          "outputGlobs": [
            "dist/screencaptureSchema.ag.json"
          ]
        }
      },
      "asc": {
        "dependsOn": [
          "@typeagent/action-schema-compiler#tsc"
        ],
        "files": {
          "inputGlobs": [
            "src/screencaptureSchema.ts"
          ],
          "outputGlobs": [
            "dist/screencaptureSchema.pas.json"
          ]
        }
      }
    }
  }
}
