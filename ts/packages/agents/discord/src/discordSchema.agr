}
  | (please)? remove (the)? permission (override|overwrite) $(overwrite_id:word) from (the)? channel $(channel_id:word) -> {
    actionName: "deleteChannelPermission",
    parameters: {
        channel_id,
        overwrite_id
    }
}
  | revoke (the)? permission $(overwrite_id:word) (from|on) channel $(channel_id:word) -> {
    actionName: "deleteChannelPermission",
    parameters: {
        channel_id,
        overwrite_id
    }
}
  | clear (the)? permission $(overwrite_id:word) (from|on) channel $(channel_id:word) -> {
    actionName: "deleteChannelPermission",
    parameters: {
        channel_id,
        overwrite_id
    }
};

// followAnnouncementChannel
<FollowAnnouncementChannel> = (can you)? follow (the)? announcement channel $(channel_id:word) (in|to) $(webhook_channel_id:word) -> {
    actionName: "followAnnouncementChannel",
    parameters: {
        channel_id,
        webhook_channel_id
    }
}
  | (please)? subscribe to (the)? announcement channel $(channel_id:word) (sending to|in) $(webhook_channel_id:word) -> {
    actionName: "followAnnouncementChannel",
    parameters: {
        channel_id,
        webhook_channel_id
    }
}
  | forward (the)? announcements from (channel)? $(channel_id:word) to (channel)? $(webhook_channel_id:word) -> {
    actionName: "followAnnouncementChannel",
    parameters: {
        channel_id,
        webhook_channel_id
    }
}
  | crosspost (the)? announcement channel $(channel_id:word) to $(webhook_channel_id:word) -> {
    actionName: "followAnnouncementChannel",
    parameters: {
        channel_id,
        webhook_channel_id
    }
};

// triggerTypingIndicator
<TriggerTypingIndicator> = (can you)? trigger (the)? typing indicator in (the)? channel $(channel_id:word) -> {
