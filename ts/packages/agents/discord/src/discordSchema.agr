    }
};

// groupDmRemoveRecipient
<GroupDmRemoveRecipient> = (can you)? remove (the)? (user|recipient) $(user_id:word) from (the)? group DM $(channel_id:word) -> {
    actionName: "groupDmRemoveRecipient",
    parameters: {
        channel_id,
        user_id
    }
}
  | (please)? kick (user)? $(user_id:word) from (the)? group DM $(channel_id:word) -> {
