// Generated grammar for Discord API actions
// This file contains common patterns for user requests
// Types: wildcard = 1+ words, word = exactly 1 word

// ============================================================
// Message Management
// ============================================================

// createMessage
<CreateMessage> = send $(content:wildcard) to channel $(channel_id:wildcard) -> {
    actionName: "createMessage",
    parameters: {
        channel_id,
        content
    }
}
  | send a message to (the)? (channel)? $(channel_id:wildcard) saying $(content:wildcard) -> {
    actionName: "createMessage",
    parameters: {
        channel_id,
        content
    }
}
  | post $(content:wildcard) in channel $(channel_id:wildcard) -> {
    actionName: "createMessage",
    parameters: {
        channel_id,
        content
    }
}
  | (can you)? create a (new)? message in (the)? (channel)? $(channel_id:wildcard) (saying|with the text|with content) $(content:wildcard) -> {
    actionName: "createMessage",
    parameters: {
        channel_id,
        content
    }
}
  | (please)? write $(content:wildcard) in (the)? channel $(channel_id:wildcard) -> {
    actionName: "createMessage",
    parameters: {
        channel_id,
        content
    }
};

// getChannelMessages
<GetChannelMessages> = (can you)? show me (the)? (latest|recent)? messages from (the)? channel $(channel_id:wildcard) -> {
    actionName: "getChannelMessages",
    parameters: {
        channel_id
    }
}
  | (can you)? show me (the)? last ($(limit:word))? messages (in|from|in the|from the)? (channel)? $(channel_id:wildcard) -> {
    actionName: "getChannelMessages",
    parameters: {
        channel_id
    }
}
  | fetch (the)? (last)? messages from (the)? channel $(channel_id:wildcard) -> {
    actionName: "getChannelMessages",
    parameters: {
        channel_id
    }
}
  | fetch (the)? last ($(limit:word))? messages from (the)? (channel)? $(channel_id:wildcard) -> {
    actionName: "getChannelMessages",
    parameters: {
        channel_id
    }
}
  | get messages from (the)? channel $(channel_id:wildcard) -> {
    actionName: "getChannelMessages",
    parameters: {
        channel_id
    }
}
  | (please)? list (the)? messages in (the)? channel $(channel_id:wildcard) -> {
    actionName: "getChannelMessages",
    parameters: {
        channel_id
    }
};

// ============================================================
// Guild Management
// ============================================================

// createGuild
<CreateGuild> = (can you)? create a (new)? guild (called|named) $(name:wildcard) -> {
    actionName: "createGuild",
    parameters: {
        name
    }
}
  | (please)? set up a guild (called|named) $(name:wildcard) -> {
    actionName: "createGuild",
    parameters: {
        name
    }
}
  | I (need|want) a new guild (called|named) $(name:wildcard) -> {
    actionName: "createGuild",
    parameters: {
        name
    }
}
  | make a (new)? guild (called|named) $(name:wildcard) -> {
    actionName: "createGuild",
    parameters: {
        name
    }
};

// getGuild
<GetGuild> = (can you)? get (the)? (details|information) for (the)? guild (with ID)? $(guild_id:word) -> {
    actionName: "getGuild",
    parameters: {
        guild_id
    }
}
  | fetch (the)? guild (info|information|details) for (guild)? (ID)? $(guild_id:word) -> {
    actionName: "getGuild",
    parameters: {
        guild_id
    }
}
  | show me (the)? guild $(guild_id:word) -> {
    actionName: "getGuild",
    parameters: {
        guild_id
    }
}
  | I need (the)? guild (object|details) for (the)? (guild with)? ID $(guild_id:word) -> {
    actionName: "getGuild",
    parameters: {
        guild_id
    }
};

// createWebhook
<CreateWebhook> = (can you)? (create|set up) a (new)? webhook (called|named) $(name:wildcard) in (the)? channel $(channel_id:word) -> {
    actionName: "createWebhook",
    parameters: {
        channel_id,
        name
    }
}
  | (please)? make a webhook (called|named) $(name:wildcard) in (the)? channel $(channel_id:word) -> {
    actionName: "createWebhook",
    parameters: {
        channel_id,
        name
    }
}
  | I need a (new)? webhook (called|named) $(name:wildcard) in channel $(channel_id:word) -> {
    actionName: "createWebhook",
    parameters: {
        channel_id,
        name
    }
}
  | add a webhook (called|named) $(name:wildcard) to (the)? channel $(channel_id:word) -> {
    actionName: "createWebhook",
    parameters: {
        channel_id,
        name
    }
};

// getWebhook
<GetWebhook> = (can you)? (get|fetch) (the)? webhook (details|info|information) for (ID)? $(webhook_id:word) -> {
    actionName: "getWebhook",
    parameters: {
        webhook_id
    }
}
  | show me (the)? webhook $(webhook_id:word) -> {
    actionName: "getWebhook",
    parameters: {
        webhook_id
    }
}
  | I need (the)? webhook (object|info) for (the)? (ID)? $(webhook_id:word) -> {
    actionName: "getWebhook",
    parameters: {
        webhook_id
    }
}
  | (please)? get (the)? webhook (with ID)? $(webhook_id:word) -> {
    actionName: "getWebhook",
    parameters: {
        webhook_id
    }
};

// executeWebhook
<ExecuteWebhook> = (can you)? execute (the)? webhook $(webhook_id:word) with token $(webhook_token:word) (saying|with content|with message) $(content:wildcard) -> {
    actionName: "executeWebhook",
    parameters: {
        webhook_id,
        webhook_token,
        content
    }
}
  | send a message (using|via|through) (the)? webhook $(webhook_id:word) (with)? token $(webhook_token:word) (saying|with content) $(content:wildcard) -> {
    actionName: "executeWebhook",
    parameters: {
        webhook_id,
        webhook_token,
        content
    }
}
  | (please)? trigger (the)? webhook $(webhook_id:word) (with)? token $(webhook_token:word) to send $(content:wildcard) -> {
    actionName: "executeWebhook",
    parameters: {
        webhook_id,
        webhook_token,
        content
    }
}
  | fire (the)? webhook $(webhook_id:word) (with)? token $(webhook_token:word) (with message|saying) $(content:wildcard) -> {
    actionName: "executeWebhook",
    parameters: {
        webhook_id,
        webhook_token,
        content
    }
};

