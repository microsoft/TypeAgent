    parameters: {
        user_id
    }
}
  | I need (the)? (information|details) (on|for|about) (the)? user (with ID)? $(user_id:word) -> {
    actionName: "getUser",
    parameters: {
        user_id
    }
}
  | look up (the)? user $(user_id:word) -> {
    actionName: "getUser",
    parameters: {
        user_id
    }
};

