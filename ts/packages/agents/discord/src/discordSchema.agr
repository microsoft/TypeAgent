}
  | what's my user info -> {
    actionName: "getCurrentUser"
}
  | get my (profile|account) (information|details)? -> {
    actionName: "getCurrentUser"
}
  | who am I -> {
    actionName: "getCurrentUser"
};

// getUser
<GetUser> = (can you)? (get|fetch) (the)? user (details|info|information) for (ID)? $(user_id:word) -> {
    actionName: "getUser",
    parameters: {
        user_id
    }
}
  | show me (the)? user (with ID)? $(user_id:word) -> {
