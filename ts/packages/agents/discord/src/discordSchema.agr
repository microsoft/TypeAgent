        user_id
    }
};

// ============================================================
// Thread Management
// ============================================================

// startThreadFromMessage
<StartThreadFromMessage> = (can you)? start a thread from (the)? message $(message_id:word) in (the)? channel $(channel_id:word) (called|named) $(name:wildcard) -> {
    actionName: "startThreadFromMessage",
    parameters: {
        channel_id,
        message_id,
        name
    }
}
  | (please)? create a thread (called|named) $(name:wildcard) from message $(message_id:word) in channel $(channel_id:word) -> {
    actionName: "startThreadFromMessage",
    parameters: {
        channel_id,
        message_id,
        name
    }
}
  | open a thread on message $(message_id:word) in channel $(channel_id:word) (called|named) $(name:wildcard) -> {
    actionName: "startThreadFromMessage",
    parameters: {
        channel_id,
        message_id,
        name
    }
}
  | make a thread from message $(message_id:word) in channel $(channel_id:word) -> {
    actionName: "startThreadFromMessage",
    parameters: {
        channel_id,
        message_id
    }
};

// startThreadWithoutMessage
<StartThreadWithoutMessage> = (can you)? start a thread (called|named) $(name:wildcard) in (the)? channel $(channel_id:word) -> {
    actionName: "startThreadWithoutMessage",
    parameters: {
        channel_id,
        name
    }
}
  | (please)? create a (new)? thread (called|named) $(name:wildcard) in channel $(channel_id:word) -> {
    actionName: "startThreadWithoutMessage",
    parameters: {
        channel_id,
        name
    }
}
  | open a (new)? thread in channel $(channel_id:word) (called|named) $(name:wildcard) -> {
    actionName: "startThreadWithoutMessage",
    parameters: {
        channel_id,
        name
    }
}
  | make a thread (called|named) $(name:wildcard) in channel $(channel_id:word) -> {
    actionName: "startThreadWithoutMessage",
    parameters: {
        channel_id,
        name
    }
};

// startThreadInForumOrMediaChannel
<StartThreadInForumOrMediaChannel> = (can you)? start a (forum|media) thread (called|named) $(name:wildcard) in (the)? channel $(channel_id:word) -> {
    actionName: "startThreadInForumOrMediaChannel",
    parameters: {
        channel_id,
        name
    }
}
  | (please)? create a (forum|media) (post|thread) (called|named) $(name:wildcard) in channel $(channel_id:word) -> {
    actionName: "startThreadInForumOrMediaChannel",
    parameters: {
        channel_id,
        name
    }
}
  | post a (new)? (forum|media) thread (called|named) $(name:wildcard) in channel $(channel_id:word) -> {
    actionName: "startThreadInForumOrMediaChannel",
    parameters: {
        channel_id,
        name
    }
}
  | make a (forum|media) post (called|named) $(name:wildcard) in channel $(channel_id:word) -> {
    actionName: "startThreadInForumOrMediaChannel",
    parameters: {
        channel_id,
        name
    }
};

// joinThread
<JoinThread> = (can you)? join (the)? thread $(channel_id:word) -> {
    actionName: "joinThread",
    parameters: {
        channel_id
    }
}
  | (please)? add me to (the)? thread $(channel_id:word) -> {
    actionName: "joinThread",
    parameters: {
        channel_id
    }
}
  | I want to join (the)? thread $(channel_id:word) -> {
    actionName: "joinThread",
    parameters: {
        channel_id
    }
}
  | enter (the)? thread $(channel_id:word) -> {
    actionName: "joinThread",
    parameters: {
        channel_id
    }
};

// addThreadMember
<AddThreadMember> = (can you)? add (the)? (user|member) $(user_id:word) to (the)? thread $(channel_id:word) -> {
    actionName: "addThreadMember",
    parameters: {
        channel_id,
        user_id
    }
}
  | (please)? invite (user)? $(user_id:word) to (the)? thread $(channel_id:word) -> {
    actionName: "addThreadMember",
    parameters: {
        channel_id,
        user_id
    }
}
  | include (user)? $(user_id:word) in (the)? thread $(channel_id:word) -> {
    actionName: "addThreadMember",
    parameters: {
        channel_id,
        user_id
    }
}
  | bring (user)? $(user_id:word) into (the)? thread $(channel_id:word) -> {
    actionName: "addThreadMember",
    parameters: {
        channel_id,
        user_id
    }
};

// leaveThread
<LeaveThread> = (can you)? leave (the)? thread $(channel_id:word) -> {
    actionName: "leaveThread",
    parameters: {
        channel_id
    }
}
  | I want to leave (the)? thread $(channel_id:word) -> {
    actionName: "leaveThread",
    parameters: {
        channel_id
    }
}
  | (please)? remove me from (the)? thread $(channel_id:word) -> {
    actionName: "leaveThread",
    parameters: {
        channel_id
    }
}
  | exit (the)? thread $(channel_id:word) -> {
    actionName: "leaveThread",
    parameters: {
        channel_id
    }
};

// removeThreadMember
<RemoveThreadMember> = (can you)? remove (the)? (user|member) $(user_id:word) from (the)? thread $(channel_id:word) -> {
    actionName: "removeThreadMember",
    parameters: {
        channel_id,
        user_id
    }
}
  | (please)? kick (user)? $(user_id:word) from (the)? thread $(channel_id:word) -> {
    actionName: "removeThreadMember",
    parameters: {
        channel_id,
        user_id
    }
}
  | take (user)? $(user_id:word) out of (the)? thread $(channel_id:word) -> {
    actionName: "removeThreadMember",
    parameters: {
        channel_id,
        user_id
    }
}
  | exclude (user)? $(user_id:word) from (the)? thread $(channel_id:word) -> {
    actionName: "removeThreadMember",
    parameters: {
        channel_id,
        user_id
    }
};

// getThreadMember
<GetThreadMember> = (can you)? get (the)? (thread)? member (info|details) for (user)? $(user_id:word) in (the)? thread $(channel_id:word) -> {
    actionName: "getThreadMember",
    parameters: {
        channel_id,
        user_id
    }
}
  | show me (the)? member $(user_id:word) in (the)? thread $(channel_id:word) -> {
    actionName: "getThreadMember",
    parameters: {
        channel_id,
        user_id
    }
}
  | fetch (the)? thread member $(user_id:word) from (the)? thread $(channel_id:word) -> {
    actionName: "getThreadMember",
    parameters: {
        channel_id,
        user_id
    }
}
  | is (user)? $(user_id:word) in (the)? thread $(channel_id:word) -> {
    actionName: "getThreadMember",
    parameters: {
        channel_id,
        user_id
    }
};

// listThreadMembers
<ListThreadMembers> = (can you)? list (the)? (thread)? members (of|in) (the)? thread $(channel_id:word) -> {
    actionName: "listThreadMembers",
    parameters: {
        channel_id
    }
}
  | show me (all)? (the)? members (of|in) (the)? thread $(channel_id:word) -> {
