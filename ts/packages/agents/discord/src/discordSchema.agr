        channel_id
    }
}
  | send (a)? typing (indicator|notification) (to|in) (the)? channel $(channel_id:word) -> {
    actionName: "triggerTypingIndicator",
    parameters: {
        channel_id
    }
};

// groupDmAddRecipient
<GroupDmAddRecipient> = (can you)? add (the)? (user|recipient) $(user_id:word) to (the)? group DM $(channel_id:word) -> {
