// ============================================================
// Server/Guild Setup
// ============================================================

<SetGuild> = (can you)? set my discord (server|guild) (to|id)? $(guild_id:word) -> {
    actionName: "setGuild",
    parameters: {
        guild_id
    }
}
  | my discord (server|guild) (id|is)? $(guild_id:word) -> {
    actionName: "setGuild",
    parameters: {
        guild_id
    }
}
  | use (discord)? (server|guild) $(guild_id:word) -> {
    actionName: "setGuild",
    parameters: {
        guild_id
    }
};

// ============================================================
// Channel Listing & Refresh
// ============================================================

<ListChannels> = (can you)? (list|show|show me) (all|the|my)? (discord)? channels -> {
    actionName: "listChannels"
}
  | what (discord)? channels (are|do I have|are available)? -> {
    actionName: "listChannels"
};

<RefreshChannels> = (can you)? refresh (the)? (discord)? (channel)? (cache|channels|list) -> {
    actionName: "refreshChannels"
}
  | (please)? update (the)? (discord)? channel (cache|list) -> {
    actionName: "refreshChannels"
};

