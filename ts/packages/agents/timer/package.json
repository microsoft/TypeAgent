{
  "name": "timer-agent",
  "version": "0.0.1",
  "private": true,
  "description": "Timer dispatcher agent for setting reminders that fire as agent-initiated messages",
  "keywords": [
    "typeagent-agent"
  ],
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/agents/timer"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "exports": {
    "./agent/manifest": "./src/timerManifest.json",
    "./agent/handlers": "./dist/timerActionHandler.js"
  },
  "scripts": {
    "agc": "agc -i ./src/timerSchema.agr -o ./dist/timerSchema.ag.json",
    "asc": "asc -i ./src/timerSchema.ts -o ./dist/timerSchema.pas.json -t TimerAction",
    "build": "concurrently npm:tsc npm:asc npm:agc",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "prettier": "prettier --check . --ignore-path ../../../.prettierignore",
    "prettier:fix": "prettier --write . --ignore-path ../../../.prettierignore",
    "tsc": "tsc -b"
  },
  "dependencies": {
    "@typeagent/agent-sdk": "workspace:*"
  },
  "devDependencies": {
    "@typeagent/action-grammar-compiler": "workspace:*",
    "@typeagent/action-schema-compiler": "workspace:*",
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "~5.4.5"
  },
  "fluidBuild": {
    "tasks": {
      "agc": {
        "dependsOn": [
          "@typeagent/action-grammar-compiler#tsc"
        ],
        "files": {
          "inputGlobs": [
            "src/timerSchema.agr"
          ],
          "outputGlobs": [
            "dist/timerSchema.ag.json"
          ]
        }
      },
      "asc": {
        "dependsOn": [
          "@typeagent/action-schema-compiler#tsc"
        ],
        "files": {
          "inputGlobs": [
            "src/timerSchema.ts"
          ],
          "outputGlobs": [
            "dist/timerSchema.pas.json"
          ]
        }
      }
    }
  },
  "typeagent": {
    "defaultAgentName": "timer"
  }
}
