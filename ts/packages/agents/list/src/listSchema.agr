// Generated grammar for listSchema
// This file contains common patterns for user requests
// Types: wildcard = 1+ words, word = exactly 1 word

// addItems - add one or more items to a list
//
// TODO: these rules bind a bare determiner as the list name — "add ham to the
// list" / "add ham to that list" match here and yield listName="the" / "that"
// instead of letting the LLM clarify which list. As a stopgap the translate
// stability test marks that case with "skipGrammar" (see translate-e2e.json and
// translateTestCommon.ts) so it bypasses grammar matching. Proper fix: constrain
// $(listName:...) to reject bare determiners (the/a/an/this/that/these/those/
// my/your/... + "list") via a registered entity type, then drop skipGrammar.
<AddItems> = add $(item:wildcard) to (the)? (my)? $(listName:wildcard) list -> {
    actionName: "addItems",
    parameters: {
        items: [item],
        listName
    }
}
  | (can you)? add $(item:wildcard) to (the)? $(listName:wildcard) -> {
    actionName: "addItems",
    parameters: {
        items: [item],
        listName
    }
}
  | put $(item:wildcard) on (the)? (my)? $(listName:wildcard) (list)? -> {
    actionName: "addItems",
    parameters: {
        items: [item],
        listName
    }
}
  | add $(item1:wildcard) and $(item2:wildcard) to (the)? $(listName:wildcard) -> {
    actionName: "addItems",
    parameters: {
        items: [item1, item2],
        listName
    }
};

// removeItems - remove one or more items from a list
<RemoveItems> = remove $(item:wildcard) from (the)? (my)? $(listName:wildcard) list -> {
    actionName: "removeItems",
    parameters: {
        items: [item],
        listName
    }
}
  | (can you)? delete $(item:wildcard) from (the)? $(listName:wildcard) -> {
    actionName: "removeItems",
    parameters: {
        items: [item],
        listName
    }
}
  | take $(item:wildcard) off (the)? (my)? $(listName:wildcard) (list)? -> {
    actionName: "removeItems",
    parameters: {
        items: [item],
        listName
    }
};

// createList - create a new list
<CreateList> = create (a)? (new)? $(listName:wildcard) list -> {
    actionName: "createList",
    parameters: {
        listName
    }
}
  | (can you)? make (me)? (a)? (new)? $(listName:wildcard) list -> {
    actionName: "createList",
    parameters: {
        listName
    }
}
  | start (a)? (new)? $(listName:wildcard) list -> {
    actionName: "createList",
    parameters: {
        listName
    }
};

// getList - show what's on the list
// Note: Each rule must have at least one distinctive required word before the wildcard
<GetList> = what's on (the)? (my)? $(listName:wildcard) (list)? -> {
    actionName: "getList",
    parameters: {
        listName
    }
}
  | what (is)? on (the)? (my)? $(listName:wildcard) (list)? -> {
    actionName: "getList",
    parameters: {
        listName
    }
}
  | what's (the)? (my)? $(listName:wildcard) list -> {
    actionName: "getList",
    parameters: {
        listName
    }
}
  | show (me)? (the)? (my)? $(listName:wildcard) list -> {
    actionName: "getList",
    parameters: {
        listName
    }
}
  | (can you)? show (me)? (the)? $(listName:wildcard) list -> {
    actionName: "getList",
    parameters: {
        listName
    }
}
  | what (do)? I have on (the)? (my)? $(listName:wildcard) list -> {
    actionName: "getList",
    parameters: {
        listName
    }
};

// clearList - clear all items from a list
<ClearList> = clear (the)? (my)? $(listName:wildcard) list -> {
    actionName: "clearList",
    parameters: {
        listName
    }
}
  | (can you)? empty (the)? (my)? $(listName:wildcard) (list)? -> {
    actionName: "clearList",
    parameters: {
        listName
    }
}
  | delete (everything)? (all items)? from (the)? (my)? $(listName:wildcard) list -> {
    actionName: "clearList",
    parameters: {
        listName
    }
};

import { ListAction } from "./listSchema.ts";

<Start> : ListAction = <AddItems>
  | <RemoveItems>
  | <CreateList>
  | <GetList>
  | <ClearList>;
