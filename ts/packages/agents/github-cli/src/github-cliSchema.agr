    actionName: "runView",
    parameters: {
        id
    }
}
  | details for the workflow run with ID $(id:word) -> {
    actionName: "runView",
    parameters: {
        id
    }
}
  | details of the workflow run with ID $(id:word) -> {
    actionName: "runView",
    parameters: {
        id
    }
}
  | workflow run with ID $(id:word) -> {
    actionName: "runView",
    parameters: {
        id
    }
}
  | workflow run details for ID $(id:word) -> {
    actionName: "runView",
    parameters: {
        id
    }
}
  | workflow run details for $(id:word) -> {
