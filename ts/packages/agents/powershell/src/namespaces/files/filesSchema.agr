// PowerShell Files Namespace Grammar
// File system operations: list, read, write, copy, move, delete, search

import { PowerShellFilesActions } from "./filesActionsSchema.ts";

<Start> : PowerShellFilesActions = <ListFiles>
          | <ReadFile>
          | <WriteFile>
          | <CopyFile>
          | <MoveFile>
          | <DeleteFile>
          | <TestPath>
          | <FindText>
          | <NewItem>;

<ListFiles> =
    (list|show|display) (all)? (the)? files (in|at|under)? $(path:wildcard)?
      -> { actionName: "listFiles", parameters: { path } }
  | ls $(path:wildcard)?
      -> { actionName: "listFiles", parameters: { path } }
  | dir $(path:wildcard)?
      -> { actionName: "listFiles", parameters: { path } }
  | (what|what's) (is)? in $(path:wildcard)
      -> { actionName: "listFiles", parameters: { path } }
  | (list|show) (my)? $(path:wildcard) (files)?
      -> { actionName: "listFiles", parameters: { path } };

<ReadFile> =
    (read|show|display|cat|type) (the)? (contents of|file)? $(path:wildcard)
      -> { actionName: "readFile", parameters: { path } }
  | (show|get) (the)? (last|tail) $(tail:number) lines (of|from|in) $(path:wildcard)
      -> { actionName: "readFile", parameters: { path, tail } }
  | (show|get) (the)? (first|head) $(head:number) lines (of|from|in) $(path:wildcard)
      -> { actionName: "readFile", parameters: { path, head } }
  | tail $(path:wildcard)
      -> { actionName: "readFile", parameters: { path, tail: 50 } };

<WriteFile> =
    write $(content:wildcard) to $(path:wildcard)
      -> { actionName: "writeFile", parameters: { path, content } }
  | save $(content:wildcard) (to|as) $(path:wildcard)
      -> { actionName: "writeFile", parameters: { path, content } }
  | append $(content:wildcard) to $(path:wildcard)
      -> { actionName: "writeFile", parameters: { path, content, append: true } };

<CopyFile> =
    copy $(source:wildcard) to $(destination:wildcard)
      -> { actionName: "copyFile", parameters: { source, destination } }
  | cp $(source:wildcard) $(destination:wildcard)
      -> { actionName: "copyFile", parameters: { source, destination } }
  | duplicate $(source:wildcard) (to|as) $(destination:wildcard)
      -> { actionName: "copyFile", parameters: { source, destination } };

<MoveFile> =
    move $(source:wildcard) to $(destination:wildcard)
      -> { actionName: "moveFile", parameters: { source, destination } }
  | mv $(source:wildcard) $(destination:wildcard)
      -> { actionName: "moveFile", parameters: { source, destination } }
  | rename $(source:wildcard) to $(destination:wildcard)
      -> { actionName: "moveFile", parameters: { source, destination } };

<DeleteFile> =
    delete $(path:wildcard)
      -> { actionName: "deleteFile", parameters: { path } }
  | remove $(path:wildcard)
      -> { actionName: "deleteFile", parameters: { path } }
  | rm $(path:wildcard)
      -> { actionName: "deleteFile", parameters: { path } };

<TestPath> =
    (check|test) if $(path:wildcard) exists
      -> { actionName: "testPath", parameters: { path } }
  | does $(path:wildcard) exist
      -> { actionName: "testPath", parameters: { path } }
  | (is there|is there a) (file|folder|directory)? (at|named)? $(path:wildcard)
      -> { actionName: "testPath", parameters: { path } };

<FindText> =
    (find|search|grep) $(pattern:wildcard) (in)? $(path:wildcard)?
      -> { actionName: "findText", parameters: { pattern, path } }
  | (search|look) for $(pattern:wildcard) (in)? $(path:wildcard)?
      -> { actionName: "findText", parameters: { pattern, path } }
  | grep $(pattern:wildcard) $(path:wildcard)?
      -> { actionName: "findText", parameters: { pattern, path } };

<NewItem> =
    (create|make) (a)? (new)? file $(path:wildcard)
      -> { actionName: "newItem", parameters: { path, itemType: "file" } }
  | (create|make) (a)? (new)? (folder|directory) $(path:wildcard)
      -> { actionName: "newItem", parameters: { path, itemType: "directory" } }
  | mkdir $(path:wildcard)
      -> { actionName: "newItem", parameters: { path, itemType: "directory" } }
  | touch $(path:wildcard)
      -> { actionName: "newItem", parameters: { path, itemType: "file" } };
