// PowerShell System Namespace Grammar
// System information and diagnostics

import { PowerShellSystemActions } from "./systemActionsSchema.ts";

<Start> : PowerShellSystemActions = <SystemInfo>
          | <DiskUsage>
          | <HotFixes>
          | <Uptime>
          | <EnvVars>;

<SystemInfo> =
    (show|get|display) system (info|information)
      -> { actionName: "systemInfo", parameters: {} }
  | (show|get) computer (info|information)
      -> { actionName: "systemInfo", parameters: {} }
  | about this (pc|computer|machine)
      -> { actionName: "systemInfo", parameters: {} }
  | system (info|information|details)
      -> { actionName: "systemInfo", parameters: {} };

<DiskUsage> =
    (show|get|display) disk (usage|space)
      -> { actionName: "diskUsage", parameters: {} }
  | (how much|show) (free|available)? (disk)? space
      -> { actionName: "diskUsage", parameters: {} }
  | drive (usage|space|capacity)
      -> { actionName: "diskUsage", parameters: {} }
  | (show|get) $(driveLetter:wildcard) drive (space|usage)?
      -> { actionName: "diskUsage", parameters: { driveLetter } }
  | df
      -> { actionName: "diskUsage", parameters: {} };

<HotFixes> =
    (show|list|get) (installed)? (hotfixes|updates|patches)
      -> { actionName: "hotFixes", parameters: {} }
  | (what)? updates (are)? installed
      -> { actionName: "hotFixes", parameters: {} }
  | windows updates
      -> { actionName: "hotFixes", parameters: {} };

<Uptime> =
    (show|get) (system)? uptime
      -> { actionName: "uptime", parameters: {} }
  | how long has (this|the) (computer|system|machine) been (running|on|up)
      -> { actionName: "uptime", parameters: {} }
  | when did (this|the) (computer|system) (start|boot)
      -> { actionName: "uptime", parameters: {} }
  | (system)? boot time
      -> { actionName: "uptime", parameters: {} }
  | uptime
      -> { actionName: "uptime", parameters: {} };

<EnvVars> =
    (show|list|get) (environment|env) (variables|vars)
      -> { actionName: "envVars", parameters: {} }
  | (show|get) (environment|env) (variable|var)? $(name:wildcard)
      -> { actionName: "envVars", parameters: { name } }
  | (what is|show|get) (the)? path (variable)?
      -> { actionName: "envVars", parameters: { name: "PATH" } }
  | echo \$env:$(name:wildcard)
      -> { actionName: "envVars", parameters: { name } }
  | printenv $(name:wildcard)?
      -> { actionName: "envVars", parameters: { name } };
