// PowerShell Data Namespace Grammar
// Data transformation and file parsing

import { PowerShellDataActions } from "./dataActionsSchema.mts";

<Start> : PowerShellDataActions = <ReadJson>
          | <WriteJson>
          | <ReadCsv>
          | <WriteCsv>
          | <FilterCsv>
          | <ConvertFormat>;

<ReadJson> =
    (read|parse|load|get) json (from)? $(path:wildcard)
      -> { actionName: "readJson", parameters: { path } }
  | (read|get) $(propertyPath:wildcard) from (json)? $(path:wildcard)
      -> { actionName: "readJson", parameters: { path, propertyPath } }
  | (show|display) (json)? (file)? $(path:wildcard)
      -> { actionName: "readJson", parameters: { path } };

<WriteJson> =
    write json to $(path:wildcard)
      -> { actionName: "writeJson", parameters: { path, data: "{}" } }
  | save (as)? json to $(path:wildcard)
      -> { actionName: "writeJson", parameters: { path, data: "{}" } };

<ReadCsv> =
    (read|parse|load|import) csv (from)? $(path:wildcard)
      -> { actionName: "readCsv", parameters: { path } }
  | (show|display) csv (file)? $(path:wildcard)
      -> { actionName: "readCsv", parameters: { path } }
  | (read|load) $(path:wildcard) (as)? csv
      -> { actionName: "readCsv", parameters: { path } };

<WriteCsv> =
    write csv to $(path:wildcard)
      -> { actionName: "writeCsv", parameters: { path, data: "[]" } }
  | export (as|to)? csv $(path:wildcard)
      -> { actionName: "writeCsv", parameters: { path, data: "[]" } }
  | save (as)? csv to $(path:wildcard)
      -> { actionName: "writeCsv", parameters: { path, data: "[]" } };

<FilterCsv> =
    filter csv $(path:wildcard) where $(column:wildcard) (is|equals|matches|contains) $(pattern:wildcard)
      -> { actionName: "filterCsv", parameters: { path, column, pattern } }
  | (find|search) (in)? csv $(path:wildcard) where $(column:wildcard) (is|equals|matches) $(pattern:wildcard)
      -> { actionName: "filterCsv", parameters: { path, column, pattern } };

<ConvertFormat> =
    convert $(input:wildcard) to json
      -> { actionName: "convertFormat", parameters: { input, format: "json" } }
  | convert $(input:wildcard) to csv
      -> { actionName: "convertFormat", parameters: { input, format: "csv" } }
  | convert $(input:wildcard) to xml
      -> { actionName: "convertFormat", parameters: { input, format: "xml" } };
