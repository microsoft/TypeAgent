{
  "name": "utility-typeagent",
  "version": "0.0.1",
  "private": true,
  "description": "TypeAgent Utility — web search, web fetch, and file I/O for compiled task flows",
  "keywords": [
    "typeagent-agent"
  ],
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/agents/utility"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "exports": {
    "./agent/manifest": "./manifest.json",
    "./agent/handlers": "./dist/actionHandler.mjs"
  },
  "scripts": {
    "agc": "agc -i ./src/utilitySchema.agr -o ./dist/utilitySchema.ag.json",
    "asc": "asc -i ./src/utilitySchema.mts -o ./dist/utilitySchema.pas.json -t UtilityAction",
    "build": "concurrently npm:tsc npm:asc npm:agc",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "jest-esm": "node --no-warnings --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "prettier": "prettier --check . --ignore-path ../../../.prettierignore",
    "prettier:fix": "prettier --write . --ignore-path ../../../.prettierignore",
    "test": "npm run test:local",
    "test:local": "pnpm run jest-esm --testPathPattern=\".*[.]spec[.]js\"",
    "tsc": "tsc -b src test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.150",
    "@typeagent/agent-sdk": "workspace:*",
    "@types/html-to-text": "^9.0.4",
    "@typeagent/browser-control-rpc": "workspace:*",
    "html-to-text": "^9.0.5",
    "puppeteer": "^24.15.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@typeagent/action-grammar-compiler": "workspace:*",
    "@typeagent/action-schema-compiler": "workspace:*",
    "@types/jest": "^29.5.7",
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "~5.4.5"
  },
  "fluidBuild": {
    "tasks": {
      "agc": {
        "dependsOn": [
          "@typeagent/action-grammar-compiler#tsc"
        ],
        "files": {
          "inputGlobs": [
            "src/utilitySchema.agr"
          ],
          "outputGlobs": [
            "dist/utilitySchema.ag.json"
          ]
        }
      },
      "asc": {
        "dependsOn": [
          "@typeagent/action-schema-compiler#tsc"
        ],
        "files": {
          "inputGlobs": [
            "src/utilitySchema.mts"
          ],
          "outputGlobs": [
            "dist/utilitySchema.pas.json"
          ]
        }
      }
    }
  },
  "typeagent": {
    "defaultAgentName": "utility"
  }
}
