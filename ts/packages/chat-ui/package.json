{
  "name": "chat-ui",
  "version": "0.0.1",
  "private": true,
  "description": "Shared chat UI rendering for TypeAgent shell and Chrome extension",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/chat-ui"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./styles": "./styles/chat.css"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "jest-esm": "node --no-warnings --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test": "npm run test:local",
    "test:local": "tsc -b test/tsconfig.json && pnpm run jest-esm --testPathPattern=\".*[.]spec[.]js\""
  },
  "dependencies": {
    "@typeagent/agent-sdk": "workspace:*",
    "@typeagent/completion-ui": "workspace:*",
    "@typeagent/dispatcher-types": "workspace:*",
    "ansi_up": "^6.0.2",
    "dompurify": "^3.4.11",
    "markdown-it": "^14.2.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/markdown-it": "^14.1.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rimraf": "^6.0.1",
    "typescript": "~5.4.5"
  }
}
