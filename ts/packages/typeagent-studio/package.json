{
  "name": "typeagent-studio",
  "displayName": "TypeAgent Studio",
  "version": "0.0.1",
  "private": true,
  "description": "Developer experience for authoring, tuning, and validating TypeAgent agents (compare-and-replay, schema/grammar tuning, trace investigation).",
  "categories": [
    "Other"
  ],
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/typeagent-studio"
  },
  "license": "MIT",
  "author": "Microsoft",
  "publisher": "typeagent",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node esbuild.mjs",
    "clean": "rimraf --glob dist dist-pub *.vsix",
    "compile": "node esbuild.mjs",
    "deploy:local": "npm run package && code --install-extension dist-pub/typeagent-studio.vsix --force",
    "package": "mkdirp dist-pub && vsce package --allow-star-activation --allow-missing-repository --no-dependencies --allow-package-secrets npm -o dist-pub/typeagent-studio.vsix",
    "test:local": "tsx --test src/test/*.spec.ts",
    "vscode:prepublish": "npm run compile",
    "watch": "node esbuild.mjs --watch"
  },
  "contributes": {
    "commands": [
      {
        "command": "typeagent-studio.connectStudioService",
        "title": "Connect to Studio service",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.openImpactReport",
        "title": "Open Impact Report",
        "category": "TypeAgent Studio",
        "icon": "$(graph)"
      },
      {
        "command": "typeagent-studio.startOnboardingSession",
        "title": "Start onboarding session",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.ask",
        "title": "Ask TypeAgent about this...",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.installToSandbox",
        "title": "Install latest onboarding session to sandbox",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.resolveInstallArtifactPath",
        "title": "Resolve install artifact path",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.checkPackagingHealthGate",
        "title": "Check packaging health gate",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.enforcePackagingHealthGate",
        "title": "Enforce packaging health gate",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.clearOnboardingSession",
        "title": "Clear active onboarding session",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.runOnboardingPhase",
        "title": "Run onboarding phase",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.advanceOnboardingPhase",
        "title": "Advance onboarding phase",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.runRemainingOnboardingPhases",
        "title": "Run remaining onboarding phases",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.showOnboardingSnapshot",
        "title": "Show onboarding snapshot",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.exportOnboardingArtifact",
        "title": "Export onboarding artifact...",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.restoreOnboardingPhase",
        "title": "Restore onboarding phase",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.rerunStaleOnboardingPhases",
        "title": "Rerun stale onboarding phases",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.toggleBatchRunSummaryAutoOpen",
        "title": "Toggle auto-open summary after batch run",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.cycleInstallHealthGatePolicy",
        "title": "Cycle install health gate policy",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.setInstallHealthGatePolicy",
        "title": "Set install health gate policy",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.startSandbox",
        "title": "Start sandbox",
        "category": "TypeAgent Studio",
        "icon": "$(add)"
      },
      {
        "command": "typeagent-studio.stopSandbox",
        "title": "Stop sandbox",
        "category": "TypeAgent Studio",
        "icon": "$(debug-stop)"
      },
      {
        "command": "typeagent-studio.restartSandbox",
        "title": "Restart sandbox",
        "category": "TypeAgent Studio",
        "icon": "$(debug-restart)"
      },
      {
        "command": "typeagent-studio.refreshSandboxes",
        "title": "Refresh sandboxes",
        "category": "TypeAgent Studio",
        "icon": "$(refresh)"
      },
      {
        "command": "typeagent-studio.loadAgent",
        "title": "Load agent",
        "category": "TypeAgent Studio",
        "icon": "$(add)"
      },
      {
        "command": "typeagent-studio.addAgentsDirectory",
        "title": "Add agents directory",
        "category": "TypeAgent Studio",
        "icon": "$(new-folder)"
      },
      {
        "command": "typeagent-studio.removeAgentsDirectory",
        "title": "Remove agents directory",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.unloadAgent",
        "title": "Unload agent",
        "category": "TypeAgent Studio",
        "icon": "$(trash)"
      },
      {
        "command": "typeagent-studio.refreshCorpora",
        "title": "Refresh corpora",
        "category": "TypeAgent Studio",
        "icon": "$(refresh)"
      },
      {
        "command": "typeagent-studio.recordFeedback",
        "title": "Record feedback",
        "category": "TypeAgent Studio",
        "icon": "$(feedback)"
      },
      {
        "command": "typeagent-studio.replayCorpus",
        "title": "Replay corpus",
        "category": "TypeAgent Studio",
        "icon": "$(debug-rerun)"
      },
      {
        "command": "typeagent-studio.addExternalCorpus",
        "title": "Add external corpus",
        "category": "TypeAgent Studio",
        "icon": "$(add)"
      },
      {
        "command": "typeagent-studio.seedInRepoCorpus",
        "title": "Seed in-repo corpus",
        "category": "TypeAgent Studio",
        "icon": "$(new-file)"
      },
      {
        "command": "typeagent-studio.focusSandboxes",
        "title": "Focus Sandboxes view",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.refreshEvents",
        "title": "Refresh event log",
        "category": "TypeAgent Studio",
        "icon": "$(refresh)"
      },
      {
        "command": "typeagent-studio.clearEvents",
        "title": "Clear event log",
        "category": "TypeAgent Studio",
        "icon": "$(clear-all)"
      },
      {
        "command": "typeagent-studio.refreshCollisions",
        "title": "Refresh collisions",
        "category": "TypeAgent Studio",
        "icon": "$(refresh)"
      },
      {
        "command": "typeagent-studio.clearCollisions",
        "title": "Clear collisions",
        "category": "TypeAgent Studio",
        "icon": "$(clear-all)"
      },
      {
        "command": "typeagent-studio.scanCollisions",
        "title": "Scan grammars for collisions",
        "category": "TypeAgent Studio",
        "icon": "$(search)"
      },
      {
        "command": "typeagent-studio.buildAgentGrammar",
        "title": "Build grammar",
        "category": "TypeAgent Studio",
        "icon": "$(tools)"
      }
    ],
    "configuration": {
      "title": "TypeAgent Studio",
      "properties": {
        "typeagentStudio.onboarding.openSummaryAfterBatchRun": {
          "type": "boolean",
          "default": true,
          "description": "Open the onboarding summary document automatically after running remaining onboarding phases."
        },
        "typeagentStudio.onboarding.defaultSandboxId": {
          "type": "string",
          "default": "studio-default",
          "description": "Default sandbox id used by Studio install commands."
        },
        "typeagentStudio.onboarding.diagnosticsDefaultFileName": {
          "type": "string",
          "default": "onboarding-diagnostics.md",
          "description": "Default file name suggested by Save onboarding diagnostics bundle."
        },
        "typeagentStudio.onboarding.settingsSnapshotDefaultFileName": {
          "type": "string",
          "default": "onboarding-settings.md",
          "description": "Default file name suggested by Save onboarding settings snapshot."
        },
        "typeagentStudio.onboarding.packagingHealthReportDefaultFileName": {
          "type": "string",
          "default": "packaging-health-report.md",
          "description": "Default file name suggested by Save packaging health report."
        },
        "typeagentStudio.onboarding.onboardingSummaryDefaultFileName": {
          "type": "string",
          "default": "onboarding-summary.md",
          "description": "Default file name suggested by Save onboarding summary."
        },
        "typeagentStudio.onboarding.onboardingHealthSnapshotDefaultFileName": {
          "type": "string",
          "default": "onboarding-health-snapshot.md",
          "description": "Default file name suggested by Save onboarding health snapshot."
        },
        "typeagentStudio.onboarding.installHealthGatePolicy": {
          "type": "string",
          "enum": [
            "enforce",
            "warn"
          ],
          "default": "enforce",
          "description": "Controls sandbox install behavior when packaging health gate reports errors. 'enforce' blocks install unless explicitly bypassed; 'warn' attempts install without gate blocking."
        },
        "typeagentStudio.collisions.autoScanOnAgentChange": {
          "type": "boolean",
          "default": true,
          "description": "Automatically re-scan grammars for collisions when agents are loaded or unloaded in a sandbox, keeping the Collisions view current without a manual scan."
        },
        "typeagentStudio.agentSearchPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional directories that contain agent subdirectories (peer to 'packages/agents') to discover and load agents from — e.g. a sibling 'agents' directory in another repo or submodule. Relative paths are resolved against the detected repo root. The repo's own 'packages/agents' is always included."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "typeagent-studio.focusSandboxes",
          "when": "false"
        },
        {
          "command": "typeagent-studio.openImpactReport",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "typeagent-studio.startSandbox",
          "when": "view == typeagentStudioSandboxes",
          "group": "navigation@1"
        },
        {
          "command": "typeagent-studio.refreshSandboxes",
          "when": "view == typeagentStudioSandboxes",
          "group": "navigation@2"
        },
        {
          "command": "typeagent-studio.refreshCorpora",
          "when": "view == typeagentStudioCorpora",
          "group": "navigation@1"
        },
        {
          "command": "typeagent-studio.recordFeedback",
          "when": "view == typeagentStudioCorpora",
          "group": "navigation@2"
        },
        {
          "command": "typeagent-studio.replayCorpus",
          "when": "view == typeagentStudioCorpora",
          "group": "navigation@3"
        },
        {
          "command": "typeagent-studio.addExternalCorpus",
          "when": "view == typeagentStudioCorpora",
          "group": "navigation@4"
        },
        {
          "command": "typeagent-studio.refreshEvents",
          "when": "view == typeagentStudioEvents",
          "group": "navigation@1"
        },
        {
          "command": "typeagent-studio.clearEvents",
          "when": "view == typeagentStudioEvents",
          "group": "navigation@2"
        },
        {
          "command": "typeagent-studio.scanCollisions",
          "when": "view == typeagentStudioCollisions",
          "group": "navigation@1"
        },
        {
          "command": "typeagent-studio.refreshCollisions",
          "when": "view == typeagentStudioCollisions",
          "group": "navigation@2"
        },
        {
          "command": "typeagent-studio.clearCollisions",
          "when": "view == typeagentStudioCollisions",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "typeagent-studio.restartSandbox",
          "when": "view == typeagentStudioSandboxes && viewItem == sandbox.running",
          "group": "inline@1"
        },
        {
          "command": "typeagent-studio.stopSandbox",
          "when": "view == typeagentStudioSandboxes && viewItem == sandbox.running",
          "group": "inline@2"
        },
        {
          "command": "typeagent-studio.loadAgent",
          "when": "view == typeagentStudioSandboxes && viewItem == sandbox.running",
          "group": "inline@0"
        },
        {
          "command": "typeagent-studio.startSandbox",
          "when": "view == typeagentStudioSandboxes && viewItem == sandbox.stopped",
          "group": "inline@1"
        },
        {
          "command": "typeagent-studio.unloadAgent",
          "when": "view == typeagentStudioSandboxes && viewItem == sandboxAgent",
          "group": "inline@1"
        },
        {
          "command": "typeagent-studio.buildAgentGrammar",
          "when": "view == typeagentStudioCollisions && viewItem == studioCollisionSkippedBuildable",
          "group": "inline@0"
        },
        {
          "command": "typeagent-studio.addExternalCorpus",
          "when": "view == typeagentStudioCorpora && viewItem == corpusAgent",
          "group": "inline@1"
        },
        {
          "command": "typeagent-studio.openImpactReport",
          "when": "view == typeagentStudioCorpora && viewItem == corpusAgent",
          "group": "inline@0"
        },
        {
          "command": "typeagent-studio.seedInRepoCorpus",
          "when": "view == typeagentStudioCorpora && viewItem == corpusAgentSeed",
          "group": "inline@0"
        }
      ]
    },
    "views": {
      "typeagentStudio": [
        {
          "id": "typeagentStudioSandboxes",
          "name": "Sandboxes"
        },
        {
          "id": "typeagentStudioCorpora",
          "name": "Corpora"
        },
        {
          "id": "typeagentStudioEvents",
          "name": "Event Log"
        },
        {
          "id": "typeagentStudioCollisions",
          "name": "Collisions"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "typeagentStudio",
          "title": "TypeAgent Studio",
          "icon": "$(beaker)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "typeagentStudioSandboxes",
        "contents": "Connecting to the TypeAgent Studio service…\nThis is automatic — the **Studio** item in the status bar shows the live connection state. If it never connects, open this workspace's `ts` folder or run `typeagent-studio serve`.",
        "when": "!typeagentStudio.serviceConnected"
      },
      {
        "view": "typeagentStudioCorpora",
        "contents": "Connecting to the TypeAgent Studio service…\nThis is automatic — the **Studio** item in the status bar shows the live connection state.",
        "when": "!typeagentStudio.serviceConnected"
      },
      {
        "view": "typeagentStudioEvents",
        "contents": "Connecting to the TypeAgent Studio service…\nThis is automatic — the **Studio** item in the status bar shows the live connection state.",
        "when": "!typeagentStudio.serviceConnected"
      },
      {
        "view": "typeagentStudioCollisions",
        "contents": "Connecting to the TypeAgent Studio service…\nThis is automatic — the **Studio** item in the status bar shows the live connection state.",
        "when": "!typeagentStudio.serviceConnected"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:typeagentStudioSandboxes",
    "onView:typeagentStudioCorpora",
    "onView:typeagentStudioEvents",
    "onView:typeagentStudioCollisions",
    "onCommand:typeagent-studio.connectStudioService",
    "onCommand:typeagent-studio.openImpactReport",
    "onCommand:typeagent-studio.startOnboardingSession",
    "onCommand:typeagent-studio.ask",
    "onCommand:typeagent-studio.installToSandbox",
    "onCommand:typeagent-studio.resolveInstallArtifactPath",
    "onCommand:typeagent-studio.checkPackagingHealthGate",
    "onCommand:typeagent-studio.enforcePackagingHealthGate",
    "onCommand:typeagent-studio.clearOnboardingSession",
    "onCommand:typeagent-studio.runOnboardingPhase",
    "onCommand:typeagent-studio.runRemainingOnboardingPhases",
    "onCommand:typeagent-studio.advanceOnboardingPhase",
    "onCommand:typeagent-studio.showOnboardingSnapshot",
    "onCommand:typeagent-studio.exportOnboardingArtifact",
    "onCommand:typeagent-studio.restoreOnboardingPhase",
    "onCommand:typeagent-studio.rerunStaleOnboardingPhases",
    "onCommand:typeagent-studio.toggleBatchRunSummaryAutoOpen",
    "onCommand:typeagent-studio.cycleInstallHealthGatePolicy",
    "onCommand:typeagent-studio.setInstallHealthGatePolicy",
    "onCommand:typeagent-studio.startSandbox",
    "onCommand:typeagent-studio.stopSandbox",
    "onCommand:typeagent-studio.restartSandbox",
    "onCommand:typeagent-studio.loadAgent",
    "onCommand:typeagent-studio.addAgentsDirectory",
    "onCommand:typeagent-studio.removeAgentsDirectory",
    "onCommand:typeagent-studio.unloadAgent",
    "onCommand:typeagent-studio.refreshSandboxes",
    "onCommand:typeagent-studio.refreshCorpora",
    "onCommand:typeagent-studio.recordFeedback",
    "onCommand:typeagent-studio.replayCorpus",
    "onCommand:typeagent-studio.addExternalCorpus",
    "onCommand:typeagent-studio.seedInRepoCorpus",
    "onCommand:typeagent-studio.refreshEvents",
    "onCommand:typeagent-studio.clearEvents",
    "onCommand:typeagent-studio.refreshCollisions",
    "onCommand:typeagent-studio.clearCollisions",
    "onCommand:typeagent-studio.scanCollisions",
    "onCommand:typeagent-studio.buildAgentGrammar"
  ],
  "dependencies": {
    "@typeagent/agent-rpc": "workspace:*",
    "@typeagent/agent-server-client": "workspace:*",
    "@typeagent/core": "workspace:*",
    "@typeagent/websocket-utils": "workspace:*",
    "debug": "^4.4.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.0",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.5.10",
    "@vscode/codicons": "^0.0.42",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.28.1",
    "mkdirp": "^3.0.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0"
  },
  "engines": {
    "vscode": "^1.90.0"
  }
}
