{
  "name": "typeagent-studio",
  "displayName": "TypeAgent Studio",
  "version": "0.0.1",
  "private": true,
  "description": "Developer experience for authoring, tuning, and validating TypeAgent agents (compare-and-replay, schema/grammar tuning, trace investigation).",
  "categories": [
    "Other"
  ],
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/typeagent-studio"
  },
  "license": "MIT",
  "author": "Microsoft",
  "publisher": "typeagent",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node esbuild.mjs",
    "clean": "rimraf --glob dist dist-pub *.vsix",
    "compile": "node esbuild.mjs",
    "deploy:local": "npm run package && code --install-extension dist-pub/typeagent-studio.vsix --force",
    "package": "mkdirp dist-pub && vsce package --allow-star-activation --allow-missing-repository --no-dependencies --allow-package-secrets npm -o dist-pub/typeagent-studio.vsix",
    "test:local": "tsx --test src/test/*.spec.ts",
    "vscode:prepublish": "npm run compile",
    "watch": "node esbuild.mjs --watch"
  },
  "contributes": {
    "configuration": {
      "title": "TypeAgent Studio",
      "properties": {
        "typeagentStudio.onboarding.openSummaryAfterBatchRun": {
          "type": "boolean",
          "default": true,
          "description": "Open the onboarding summary document automatically after running remaining onboarding phases."
        },
        "typeagentStudio.onboarding.defaultSandboxId": {
          "type": "string",
          "default": "studio-default",
          "description": "Default sandbox id used by Studio install commands."
        },
        "typeagentStudio.onboarding.diagnosticsDefaultFileName": {
          "type": "string",
          "default": "onboarding-diagnostics.md",
          "description": "Default file name suggested by Save onboarding diagnostics bundle."
        },
        "typeagentStudio.onboarding.installHealthGatePolicy": {
          "type": "string",
          "enum": [
            "enforce",
            "warn"
          ],
          "default": "enforce",
          "description": "Controls sandbox install behavior when packaging health gate reports errors. 'enforce' blocks install unless explicitly bypassed; 'warn' attempts install without gate blocking."
        }
      }
    },
    "commands": [
      {
        "command": "typeagent-studio.hello",
        "title": "Hello (skeleton)",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.startOnboardingSession",
        "title": "Start onboarding session",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.ask",
        "title": "Ask TypeAgent about this...",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.installToSandbox",
        "title": "Install latest onboarding session to sandbox",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.resolveInstallArtifactPath",
        "title": "Resolve install artifact path",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.copyInstallArtifactPath",
        "title": "Copy install artifact path",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.checkPackagingHealthGate",
        "title": "Check packaging health gate",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.enforcePackagingHealthGate",
        "title": "Enforce packaging health gate",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.openPackagingHealthReport",
        "title": "Open packaging health report",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.copyPackagingHealthReport",
        "title": "Copy packaging health report",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.clearOnboardingSession",
        "title": "Clear active onboarding session",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.runOnboardingPhase",
        "title": "Run onboarding phase",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.advanceOnboardingPhase",
        "title": "Advance onboarding phase",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.runRemainingOnboardingPhases",
        "title": "Run remaining onboarding phases",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.showOnboardingSnapshot",
        "title": "Show onboarding snapshot",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.showOnboardingHealthSnapshot",
        "title": "Show onboarding health snapshot",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.copyOnboardingHealthSnapshot",
        "title": "Copy onboarding health snapshot",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.showOnboardingSettingsSnapshot",
        "title": "Show onboarding settings snapshot",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.copyOnboardingSettingsSnapshot",
        "title": "Copy onboarding settings snapshot",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.openOnboardingSettingsSnapshot",
        "title": "Open onboarding settings snapshot",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.restoreOnboardingPhase",
        "title": "Restore onboarding phase",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.rerunStaleOnboardingPhases",
        "title": "Rerun stale onboarding phases",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.openOnboardingSummary",
        "title": "Open onboarding summary",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.copyOnboardingSummary",
        "title": "Copy onboarding summary",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.saveOnboardingSummary",
        "title": "Save onboarding summary",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.saveOnboardingDiagnosticsBundle",
        "title": "Save onboarding diagnostics bundle",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.openOnboardingDiagnosticsBundle",
        "title": "Open onboarding diagnostics bundle",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.copyOnboardingDiagnosticsBundle",
        "title": "Copy onboarding diagnostics bundle",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.toggleBatchRunSummaryAutoOpen",
        "title": "Toggle auto-open summary after batch run",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.cycleInstallHealthGatePolicy",
        "title": "Cycle install health gate policy",
        "category": "TypeAgent Studio"
      },
      {
        "command": "typeagent-studio.setInstallHealthGatePolicy",
        "title": "Set install health gate policy",
        "category": "TypeAgent Studio"
      }
    ]
  },
  "activationEvents": [
    "onCommand:typeagent-studio.hello",
    "onCommand:typeagent-studio.startOnboardingSession",
    "onCommand:typeagent-studio.ask",
    "onCommand:typeagent-studio.installToSandbox",
    "onCommand:typeagent-studio.resolveInstallArtifactPath",
    "onCommand:typeagent-studio.copyInstallArtifactPath",
    "onCommand:typeagent-studio.checkPackagingHealthGate",
    "onCommand:typeagent-studio.enforcePackagingHealthGate",
    "onCommand:typeagent-studio.openPackagingHealthReport",
    "onCommand:typeagent-studio.copyPackagingHealthReport",
    "onCommand:typeagent-studio.clearOnboardingSession",
    "onCommand:typeagent-studio.runOnboardingPhase",
    "onCommand:typeagent-studio.runRemainingOnboardingPhases",
    "onCommand:typeagent-studio.advanceOnboardingPhase",
    "onCommand:typeagent-studio.showOnboardingSnapshot",
    "onCommand:typeagent-studio.showOnboardingHealthSnapshot",
    "onCommand:typeagent-studio.copyOnboardingHealthSnapshot",
    "onCommand:typeagent-studio.showOnboardingSettingsSnapshot",
    "onCommand:typeagent-studio.copyOnboardingSettingsSnapshot",
    "onCommand:typeagent-studio.openOnboardingSettingsSnapshot",
    "onCommand:typeagent-studio.restoreOnboardingPhase",
    "onCommand:typeagent-studio.rerunStaleOnboardingPhases",
    "onCommand:typeagent-studio.openOnboardingSummary",
    "onCommand:typeagent-studio.copyOnboardingSummary",
    "onCommand:typeagent-studio.saveOnboardingSummary",
    "onCommand:typeagent-studio.saveOnboardingDiagnosticsBundle",
    "onCommand:typeagent-studio.openOnboardingDiagnosticsBundle",
    "onCommand:typeagent-studio.copyOnboardingDiagnosticsBundle",
    "onCommand:typeagent-studio.toggleBatchRunSummaryAutoOpen",
    "onCommand:typeagent-studio.cycleInstallHealthGatePolicy",
    "onCommand:typeagent-studio.setInstallHealthGatePolicy"
  ],
  "dependencies": {
    "@typeagent/core": "workspace:*",
    "debug": "^4.4.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.25.0",
    "mkdirp": "^3.0.1",
    "rimraf": "^6.0.1"
    ,"tsx": "^4.21.0"
  },
  "engines": {
    "vscode": "^1.90.0"
  }
}
