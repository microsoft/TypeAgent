{
  "description": "Service profile — lean agent set for the headless agent-server / Copilot-plugin scenario (calendar, email, music, browser + conversational/system/PowerShell). Omits heavy media/dev agents (code, photo, image, markdown, montage, video, screencapture, github-cli, visualStudio, discord); those remain installable on demand. Select with: agent-server --config service.",
  "agents": {
    "player": {
      "name": "music"
    },
    "localPlayer": {
      "name": "music-local"
    },
    "calendar": {
      "name": "calendar"
    },
    "email": {
      "name": "email"
    },
    "list": {
      "name": "list-agent"
    },
    "browser": {
      "name": "browser-typeagent"
    },
    "desktop": {
      "name": "desktop-automation"
    },
    "chat": {
      "name": "chat-agent",
      "execMode": "dispatcher"
    },
    "greeting": {
      "name": "greeting-agent",
      "execMode": "dispatcher"
    },
    "settings": {
      "name": "settings-agent",
      "execMode": "dispatcher"
    },
    "weather": {
      "name": "weather-agent"
    },
    "taskflow": {
      "name": "taskflow-typeagent",
      "execMode": "dispatcher"
    },
    "powershell": {
      "name": "powershell-typeagent"
    },
    "workflow": {
      "name": "workflow-agent"
    },
    "utility": {
      "name": "utility-typeagent"
    },
    "onboarding": {
      "name": "onboarding-agent"
    },
    "osNotifications": {
      "name": "os-notifications-agent"
    },
    "timer": {
      "name": "timer-agent"
    },
    "windowsClock": {
      "name": "windowsclock-agent"
    },
    "ipconfig": {
      "name": "ipconfig-agent"
    }
  },
  "mcpServers": {
    "mcpfilesystem": {
      "emojiChar": "📁",
      "description": "File system agent",
      "defaultEnabled": false,
      "serverScript": "./node_modules/@modelcontextprotocol/server-filesystem/dist/index.js",
      "serverScriptArgs": {
        "allowedDirectories": {
          "description": "Allowed directories for the file system agent to access",
          "type": "string",
          "multiple": true
        }
      }
    }
  },
  "explainers": {
    "v5": {
      "constructions": {
        "data": ["./data/explainer/v5/data/player/basic.json"],
        "file": "./data/explainer/v5/constructions.json"
      }
    }
  },
  "tests": [
    "./test/data/explanations/**/**/*.json",
    "./test/repo/explanations/**/**/*.json"
  ]
}
