// Realistic-dialogue slice: 20 HAND-AUTHORED multi-turn conversations that read
// like a regular user talking, rather than the keyword-glue preludes the
// generated slices use. Each scenario is grounded in the featured agents' REAL
// committed keyword vectors (so the discriminating words a human would naturally
// say are the words that actually move the scorer), and each carries a
// hand-assigned ground-truth label.
//
// The set deliberately MIXES outcomes — clear resolves, genuine ties, no-signal
// topic drift, and a stale mention — so the confusion matrix is fully populated
// (no `n/a` columns) and every metric is exercised on natural language.
//
// The final "ask" is the ambiguous request that would trigger the collision; it
// is history-only excluded from scoring (the tier decides from what came BEFORE),
// so it is recorded for realism but not part of the prelude.

import { Roster, TopicalAction, discriminating } from "./metricRoster.mjs";
import { Fixture } from "./metricCorpus.mjs";

type Expect =
    | { kind: "resolve"; target: string } // schema name of the intended agent
    | {
          kind: "abstain";
          reason: "tie" | "no-signal" | "stale";
      };

export type DialogueScenario = {
    id: string;
    note: string; // what a regular user is doing
    pair: [string, string]; // the two confusable agent schemas
    dialogue: string[]; // natural prior turns -> the context
    ask: string; // the ambiguous final request (not scored)
    expect: Expect;
    // Difficulty tiers (undefined = "realistic", the default 50). "simple" is the
    // easy floor (short, obvious, single-agent). "hard" probes edge cases.
    // "extra-hard" is the adversarial stress tier — inputs designed to actively
    // confuse the scorer. All labeled by honest human intent and NOT tuned to
    // pass; several hard/extra-hard cases are EXPECTED to fail. `category` groups
    // them for the report.
    difficulty?: "simple" | "hard" | "extra-hard" | "no-context";
    category?: string;
};

// 20 scenarios. RESOLVE cases embed the intended agent's discriminating words in
// natural sentences; ABSTAIN cases stay in the shared vocabulary, mention both
// agents evenly, drift to an unrelated topic, or let a lone mention go stale.
