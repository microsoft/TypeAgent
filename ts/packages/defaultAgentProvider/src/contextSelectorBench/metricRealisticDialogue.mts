// Map a scenario to a runnable Fixture using each schema's richest committed
// action. Skips a scenario if a featured schema isn't in the roster.
export function generateDialogueFixtures(roster: Roster): Fixture[] {
    const best = new Map<string, TopicalAction>();
    for (const a of roster.actions) {
        const cur = best.get(a.schemaName);
        if (cur === undefined || a.keywords.size > cur.keywords.size) {
            best.set(a.schemaName, a);
        }
    }
    const idOf = (schema: string): string | undefined => {
        const a = best.get(schema);
        return a ? `${a.schemaName}.${a.actionName}` : undefined;
    };

    const fixtures: Fixture[] = [];
    for (const s of SCENARIOS) {
        const aId = idOf(s.pair[0]);
        const bId = idOf(s.pair[1]);
        if (aId === undefined || bId === undefined) {
            continue;
        }
        const targetId =
            s.expect.kind === "resolve" ? idOf(s.expect.target) : undefined;
        if (s.expect.kind === "resolve" && targetId === undefined) {
            continue;
        }
        // Retrieval oracle (resolve scenarios only): discriminating tokens of the
        // intended agent vs the other, so topic share reflects the tell-tale
        // words a human said, not the shared domain vocabulary.
        let retrieval: Fixture["retrieval"];
        if (s.expect.kind === "resolve") {
            const target = best.get(s.expect.target);
            const other = best.get(
                s.pair[0] === s.expect.target ? s.pair[1] : s.pair[0],
            );
            if (target && other) {
                retrieval = {
                    topic: targetId!,
                    topicTokens: discriminating(
                        target.keywords,
                        other.keywords,
                    ),
                    distractorTokens: discriminating(
                        other.keywords,
                        target.keywords,
                    ),
                    unrelatedTokens: [],
                };
            }
        }
        fixtures.push({
            id: `dialogue-${s.id}`,
            prelude: s.dialogue,
            collisionInput: s.ask,
            // Keep the natural grammar order: first-featured agent first.
            candidates: [aId, bId],
            label:
                s.expect.kind === "resolve"
                    ? { kind: "resolve", target: targetId! }
                    : { kind: "abstain", reason: s.expect.reason },
            ...(retrieval ? { retrieval } : {}),
        });
    }
    return fixtures;
}
