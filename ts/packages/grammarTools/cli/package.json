{
  "name": "grammar-tools-cli",
  "version": "0.0.1",
  "private": true,
  "description": "CLI tool for grammar exploration, completion preview, and trace visualization.",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/grammarTools/cli"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "bin": {
    "grammar-tools": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run tsc",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "jest-esm": "node --no-warnings --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test": "npm run test:local",
    "test:local": "pnpm run jest-esm --testPathPattern=\".*[.]spec[.]js\"",
    "tsc": "tsc -b"
  },
  "dependencies": {
    "@typeagent/action-grammar": "workspace:*",
    "grammar-tools-core": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "typescript": "~5.4.5"
  }
}
