{
  "name": "grammar-tools-ui",
  "version": "0.0.1",
  "private": true,
  "description": "Lit web components for grammar visualization, editing, and debugging.",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/grammarTools/ui"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "vite build && tsc -b test test/components",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "dev": "vite serve dev",
    "jest-esm": "node --no-warnings --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "prettier": "prettier --check . --ignore-path ../../../.prettierignore",
    "prettier:fix": "prettier --write . --ignore-path ../../../.prettierignore",
    "test": "npm run test:local && npm run test:wtr",
    "test:local": "pnpm run jest-esm --testPathPattern=\".*[.]spec[.]js\"",
    "test:wtr": "wtr"
  },
  "dependencies": {
    "grammar-tools-core": "workspace:*",
    "lit": "^3.1.0"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@types/jest": "^29.5.0",
    "@types/mocha": "^10.0.0",
    "@web/test-runner": "^0.19.0",
    "@web/test-runner-playwright": "^0.11.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "typescript": "~5.4.5",
    "vite": "^5.4.0"
  }
}
