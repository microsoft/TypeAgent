{
  "name": "grammar-tools-ui",
  "version": "0.0.1",
  "private": true,
  "description": "Lit web components for grammar visualization, editing, and debugging.",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/grammarTools/ui"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "dev": "vite serve dev",
    "prettier": "prettier --check . --ignore-path ../../../.prettierignore",
    "prettier:fix": "prettier --write . --ignore-path ../../../.prettierignore"
  },
  "dependencies": {
    "grammar-tools-core": "workspace:*",
    "lit": "^3.1.0"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typescript": "~5.4.5",
    "vite": "^5.4.0"
  }
}
