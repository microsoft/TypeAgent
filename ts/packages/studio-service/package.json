{
  "name": "studio-service",
  "version": "0.0.1",
  "private": true,
  "description": "TypeAgent Studio service — the standalone, per-workspace host of the @typeagent/core Studio runtime and its typed service channel.",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/packages/studio-service"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "typeagent-studio-service": "./dist/main.js"
  },
  "files": [
    "dist",
    "!dist/test"
  ],
  "scripts": {
    "build": "npm run tsc",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "jest-esm": "node --no-warnings --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "prettier": "prettier --check . --ignore-path ../../.prettierignore",
    "prettier:fix": "prettier --write . --ignore-path ../../.prettierignore",
    "test": "npm run test:local",
    "test:local": "pnpm run jest-esm --testPathPattern=\".*[.]spec[.]js\"",
    "tsc": "tsc -b src test"
  },
  "dependencies": {
    "@typeagent/agent-rpc": "workspace:*",
    "@typeagent/agent-server-client": "workspace:*",
    "@typeagent/core": "workspace:*",
    "debug": "^4.4.0",
    "@typeagent/websocket-utils": "workspace:*",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/jest": "^29.5.7",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "~5.4.5"
  }
}
