{
  "name": "mcp-plan-validation",
  "version": "0.1.0",
  "description": "Plan-validated agent execution via MCP. Self-checking model loops with org policy enforcement.",
  "license": "MIT",
  "author": "Microsoft",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-plan-validation": "dist/cli.js"
  },
  "files": [
    "dist",
    "policies",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "demo": "tsx demo/run-demo.ts",
    "demo:server": "tsx demo/server.ts",
    "dev": "tsc && node dist/index.js",
    "init": "tsc && node dist/init.js",
    "test": "tsc && node dist/mcpValidationTest.js",
    "test:happy": "tsc && node dist/mcpValidationTest.js happy",
    "test:block": "tsc && node dist/mcpValidationTest.js block",
    "test:constraint": "tsc && node dist/mcpValidationTest.js constraint",
    "test:policy-unit": "tsc && node dist/mcpValidationTest.js policy-unit",
    "test:policy-integration": "tsc && node dist/mcpValidationTest.js policy-integration",
    "test:postcond-unit": "tsc && node dist/mcpValidationTest.js postcond-unit",
    "test:postcond-integration": "tsc && node dist/mcpValidationTest.js postcond-integration",
    "test:capability": "tsc && node dist/mcpValidationTest.js capability",
    "test:container": "tsc && node dist/mcpValidationTest.js container"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "fast-glob": "^3.3.3",
    "validation": "workspace:*",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "@types/node": "^20.11.19",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4"
  },
  "keywords": [
    "mcp",
    "validation",
    "agent",
    "plan",
    "policy",
    "claude",
    "copilot",
    "cursor"
  ]
}
