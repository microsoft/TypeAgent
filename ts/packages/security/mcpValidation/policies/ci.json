{
  "version": "1.0",
  "name": "ci",
  "description": "CI/CD pipeline. Read-only filesystem, tight timeouts, no interactive tools, no network. For automated validation runs.",
  "deniedTools": ["WebFetch", "WebSearch", "AskUserQuestion", "NotebookEdit"],
  "paths": {
    "allowedReadPatterns": ["{{projectDir}}/**"],
    "allowedWritePatterns": [
      "{{projectDir}}/dist/**",
      "{{projectDir}}/build/**",
      "{{projectDir}}/coverage/**",
      "/tmp/**"
    ],
    "deniedPatterns": [
      "**/.env",
      "**/.env.*",
      "**/credentials*",
      "**/*.pem",
      "**/*.key"
    ]
  },
  "bash": {
    "mode": "policy-checked",
    "allowedCommands": [
      "ls",
      "cat",
      "head",
      "tail",
      "grep",
      "find",
      "wc",
      "echo",
      "printf",
      "date",
      "git",
      "npm",
      "npx",
      "pnpm",
      "yarn",
      "node",
      "tsc",
      "jest",
      "vitest",
      "mocha",
      "prettier",
      "eslint",
      "mkdir",
      "cp"
    ],
    "deniedCommands": [
      "curl",
      "wget",
      "ssh",
      "scp",
      "nc",
      "telnet",
      "docker",
      "kubectl",
      "rm",
      "mv",
      "chmod",
      "chown"
    ],
    "denyPatterns": [
      "rm\\s+-rf",
      "\\|\\s*bash",
      "\\|\\s*sh\\b",
      ">(\\s|/dev/)(tcp|udp)/"
    ],
    "network": {
      "denyAll": true
    },
    "maxTimeoutMs": 60000
  },
  "container": {
    "enabled": false,
    "image": "node:20-slim",
    "networkMode": "none",
    "readOnly": true,
    "memoryLimit": "512m",
    "cpuLimit": "1.0",
    "pidsLimit": 100,
    "timeoutMs": 60000
  },
  "limitCaps": {
    "maxTotalSteps": 20,
    "maxDurationMs": 120000,
    "maxFileWrites": 5,
    "maxBytesWritten": 262144
  }
}
