{
  "version": "1.0",
  "name": "example-corporate-policy",
  "deniedTools": ["WebFetch", "WebSearch"],
  "paths": {
    "allowedReadPatterns": ["/home/user/project/**", "/tmp/**"],
    "allowedWritePatterns": ["/home/user/project/src/**", "/tmp/**"],
    "deniedPatterns": [
      "**/.env",
      "**/.env.*",
      "**/credentials*",
      "**/secrets*",
      "**/*.pem",
      "**/*.key"
    ]
  },
  "bash": {
    "mode": "capabilities-only",
    "allowedCommands": [
      "ls",
      "cat",
      "head",
      "tail",
      "grep",
      "find",
      "wc",
      "sort",
      "uniq",
      "echo",
      "printf",
      "date",
      "pwd",
      "whoami",
      "git",
      "npm",
      "npx",
      "node",
      "tsc",
      "prettier",
      "eslint",
      "mkdir",
      "cp",
      "mv",
      "rm",
      "touch",
      "chmod",
      "diff",
      "patch",
      "sed",
      "awk",
      "tr",
      "cut",
      "xargs"
    ],
    "deniedCommands": [
      "curl",
      "wget",
      "ssh",
      "scp",
      "nc",
      "ncat",
      "telnet",
      "ftp",
      "sftp",
      "nmap"
    ],
    "denyPatterns": [
      "rm\\s+-rf\\s+/[^t]",
      ">(\\s|/dev/)(tcp|udp)/",
      "eval\\s",
      "\\$\\(.*curl",
      "\\|\\s*bash",
      "\\|\\s*sh\\b"
    ],
    "network": {
      "denyAll": true
    },
    "maxTimeoutMs": 60000
  },
  "container": {
    "enabled": false,
    "image": "node:20-slim",
    "networkMode": "none",
    "readOnly": true,
    "memoryLimit": "512m",
    "cpuLimit": "1.0",
    "pidsLimit": 100,
    "timeoutMs": 60000
  },
  "limitCaps": {
    "maxTotalSteps": 50,
    "maxDurationMs": 300000,
    "maxFileWrites": 20,
    "maxBytesWritten": 1048576
  }
}
