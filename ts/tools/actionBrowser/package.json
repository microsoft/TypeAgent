{
  "name": "@typeagent/action-browser",
  "version": "0.0.1",
  "description": "Static generator for the TypeAgent Action Browser — a self-contained, interactive HTML catalog of every agent action, parameter, example phrasing, and system command. Produced as part of the documentation build.",
  "homepage": "https://github.com/microsoft/TypeAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/TypeAgent.git",
    "directory": "ts/tools/actionBrowser"
  },
  "license": "MIT",
  "author": "Microsoft",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "action-browser": "./dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/test"
  ],
  "scripts": {
    "build": "npm run tsc",
    "clean": "rimraf --glob dist *.tsbuildinfo *.done.build.log",
    "docs:action-browser": "node ./dist/cli.js",
    "prettier": "prettier --check . --ignore-path ../../.prettierignore",
    "prettier:fix": "prettier --write . --ignore-path ../../.prettierignore",
    "tsc": "tsc -b"
  },
  "dependencies": {
    "@typeagent/action-grammar": "workspace:*",
    "@typeagent/action-schema": "workspace:*",
    "@typeagent/agent-sdk": "workspace:*",
    "agent-dispatcher": "workspace:*",
    "default-agent-provider": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "~5.4.5"
  }
}
