# Override the repo-root .gitattributes which forces "* text eol=lf".
# VS-managed C#/XAML/csproj/vsixmanifest tooling expects CRLF and emits
# "inconsistent line endings" warnings when files are LF on disk, so
# pin those file types to CRLF for this project.
*.cs            text eol=crlf
*.xaml          text eol=crlf
*.csproj        text eol=crlf
*.sln           text eol=crlf
*.vsct          text eol=crlf
*.vsixmanifest  text eol=crlf
*.config        text eol=crlf
*.resx          text eol=crlf
*.props         text eol=crlf
*.targets       text eol=crlf
